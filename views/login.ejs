<!DOCTYPE html>
<html lang="da-DK" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow">
    <title>DVinyl · Log ind</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://rsms.me/">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="icon" type="image/png" href="<%= baseUrl %>/ressources/logo.png">
    <style>
        :root {
            --bg-page: #0a0a0a;
            --bg-card: #171717;
            --text-main: #fafafa;
            --text-sub: #a3a3a3;
            --border: rgba(255,255,255,0.08);
        }
        html.light {
            --bg-page: #fafafa;
            --bg-card: #ffffff;
            --text-main: #0a0a0a;
            --text-sub: #737373;
            --border: rgba(0,0,0,0.08);
        }
        html { font-family: 'Inter var', 'Inter', ui-sans-serif, system-ui, sans-serif; }
        body { background: var(--bg-page); color: var(--text-main); -webkit-font-smoothing: antialiased; }
        ::selection { background: var(--text-main); color: var(--bg-page); }
        :focus-visible { outline: 2px solid var(--text-main); outline-offset: 2px; border-radius: 6px; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4 py-10">

    <div class="w-full max-w-sm">

        <div class="flex items-center justify-center gap-2 mb-8">
            <span class="w-8 h-8 rounded-md bg-white/10 flex items-center justify-center">
                <i class="fa-solid fa-clapperboard text-[13px]"></i>
            </span>
            <span class="text-[17px] font-black tracking-tight">DVinyl</span>
        </div>

        <div class="text-center mb-7">
            <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-[var(--text-sub)] mb-2">Log ind</p>
            <h1 class="text-[28px] font-black leading-tight tracking-tight">Hvem er du?</h1>
        </div>

        <% if (error) { %>
        <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-300 text-[13px] flex items-center gap-2">
            <i class="fa-solid fa-circle-exclamation text-xs"></i>
            <%= error %>
        </div>
        <% } %>

        <form method="POST" action="<%= baseUrl %>/login" class="space-y-3">

            <% if (users.length > 0) { %>
            <div class="grid grid-cols-<%= Math.min(users.length, 3) %> gap-2" id="userPicker">
                <% users.forEach(u => { %>
                <button type="button"
                        data-name="<%= u.name %>"
                        class="user-btn px-3 py-3 rounded-xl text-[13px] font-bold capitalize transition border
                               <%= (prefill && prefill.toLowerCase() === u.name.toLowerCase())
                                    ? 'bg-[var(--text-main)] text-[var(--bg-page)] border-transparent'
                                    : 'bg-white/5 text-[var(--text-main)] border-[var(--border)] hover:bg-white/10' %>">
                    <%= u.name %>
                </button>
                <% }) %>
            </div>
            <% } %>

            <input type="hidden" name="name" id="nameInput" value="<%= prefill %>">

            <div class="relative">
                <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-[var(--text-sub)] text-[12px] pointer-events-none"></i>
                <input type="password" name="password" id="passwordInput" required
                       placeholder="Adgangskode"
                       class="w-full h-12 pl-11 pr-4 rounded-xl bg-white/5 border border-[var(--border)] focus:bg-white/10 focus:border-[var(--text-main)] outline-none text-[14px] transition placeholder:text-[var(--text-sub)]">
            </div>

            <button type="submit" id="loginBtn"
                    class="w-full h-12 rounded-xl bg-[var(--text-main)] text-[var(--bg-page)] text-[14px] font-bold transition disabled:opacity-30 disabled:cursor-not-allowed hover:opacity-90 active:scale-[0.98]">
                Log ind
            </button>
        </form>

        <% if (users.length === 0) { %>
        <div class="mt-6 p-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-300 text-[12px]">
            <p class="font-bold mb-1">Ingen brugere konfigureret</p>
            <p class="opacity-80">Sæt <code class="bg-amber-500/20 px-1 rounded">AUTH_USERS</code> i din .env. Format: <code class="bg-amber-500/20 px-1 rounded">navn:adgangskode,navn:adgangskode</code></p>
        </div>
        <% } %>
    </div>

    <script>
        const buttons   = document.querySelectorAll('.user-btn');
        const nameInput = document.getElementById('nameInput');
        const pwInput   = document.getElementById('passwordInput');

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => {
                    b.classList.remove('bg-[var(--text-main)]', 'text-[var(--bg-page)]', 'border-transparent');
                    b.classList.add('bg-white/5', 'text-[var(--text-main)]', 'border-[var(--border)]', 'hover:bg-white/10');
                });
                btn.classList.remove('bg-white/5', 'text-[var(--text-main)]', 'border-[var(--border)]', 'hover:bg-white/10');
                btn.classList.add('bg-[var(--text-main)]', 'text-[var(--bg-page)]', 'border-transparent');
                nameInput.value = btn.dataset.name;
                pwInput.focus();
            });
        });

        // Theme from localStorage
        try {
            const t = localStorage.getItem('dvinyl-theme');
            if (t === 'light') {
                document.documentElement.classList.remove('dark');
                document.documentElement.classList.add('light');
            }
        } catch (e) {}
    </script>
</body>
</html>

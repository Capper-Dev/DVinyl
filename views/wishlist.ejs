<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 md:px-0 pb-12">
    
    <div class="flex items-center justify-between mb-6 md:mb-8 pt-6">
        
        <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-2 md:gap-3 transition-colors truncate mr-4">
            <span class="flex items-center gap-2 md:gap-3 text-primary-theme">
                <i class="fa-solid fa-gift flex-shrink-0"></i> 
                <span class="truncate"><%= t('wishlist.title') %></span>
            </span>
            <span class="opacity-60 text-base md:text-lg font-normal transition-colors flex-shrink-0">
                (<%= albums.length %>)
            </span>
        </h1>

        <% if (user.isAdmin && user.discogsUsername) { %>
            <button onclick="refreshCollection()" id="refreshBtn" class="flex-shrink-0 w-10 h-10 md:w-auto md:h-auto md:p-2.5 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center active:scale-95 group" title="refresh discogs">
                <i class="fa-solid fa-sync group-hover:rotate-180 transition-transform duration-500"></i>
            </button>
        <% } %>

    </div>

    <% if (albums.length === 0) { %>
        <div class="text-center py-16 md:py-20 card-theme rounded-xl border-dashed opacity-80 transition-colors shadow-sm">
            <i class="fa-regular fa-heart text-5xl md:text-6xl opacity-20 mb-4 transition-colors"></i>
            <p class="opacity-60 px-4"><%= t('wishlist.empty_msg') %></p>
            <a href="/add-vinyl" class="text-primary-theme hover:underline mt-2 inline-block font-medium transition-colors">
                <%= t('wishlist.search_link') %>
            </a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-6">
            <% albums.forEach(album => { %>
                <div class="group relative card-theme rounded-lg hover:border-primary-theme transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
                    
                    <a href="/album/<%= album._id %>" class="block flex-grow">
                        <div class="aspect-square w-full overflow-hidden relative">
                            <img src="<%= album.cover_image %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy">
                            
                            <% 
                                let badgeColor = 'bg-green-600/90 text-white';
                                let badgeText = t('media.vinyl');
                                if (album.media_type === 'cd') { badgeColor = 'bg-blue-600/90 text-white'; badgeText = t('media.cd'); } 
                                else if (album.media_type === 'cassette') { badgeColor = 'bg-orange-600/90 text-white'; badgeText = t('media.cassette'); }
                            %>
                            <span class="absolute top-1.5 right-1.5 md:top-2 md:right-2 text-[10px] font-bold px-1.5 py-0.5 md:px-2 md:py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeColor %>">
                                <%= badgeText %>
                            </span>
                        </div>

                        <div class="p-2 md:p-3">
                            <h3 class="font-bold text-xs md:text-sm truncate transition-colors leading-tight mb-0.5"><%= album.title %></h3>
                            <p class="text-[10px] md:text-xs opacity-60 truncate mb-2 transition-colors"><%= album.artist %></p>

                            <% if(album.variant_color) { %>
                                <div class="flex items-center gap-1 mb-1">
                                    <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-primary-theme inline-block flex-shrink-0"></span>
                                    <span class="text-[9px] md:text-[10px] opacity-60 truncate max-w-full transition-colors"><%= album.variant_color %></span>
                                </div>
                            <% } %>
                        </div>
                    </a>

                    <% if (user.isAdmin) { %>
                        <button onclick="moveToCollection('<%= album._id %>')" class="w-full py-2.5 md:py-2 bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white text-primary-theme text-[10px] md:text-xs font-bold uppercase transition-colors flex items-center justify-center gap-1.5 border-t border-black/10 dark:border-white/10 active:brightness-90">
                            <i class="fa-solid fa-check"></i> 
                            <span><%= t('wishlist.btn_received') %></span>
                        </button>
                    <% } %>

                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const wishlistTranslations = {
        confirmMove: "<%= t('wishlist.confirm_move') %>",
        serverError: "<%= t('messages.generic_error') %>"
    };

    async function moveToCollection(id) {
        if(confirm(wishlistTranslations.confirmMove)) {
            try {
                const res = await fetch(`/api/album/${id}/move-to-collection`, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    window.location.reload();
                }
            } catch(e) { 
                alert(wishlistTranslations.serverError); 
            }
        }
    }

    <% if (user.isAdmin) { %>
        const socket = io();

        async function refreshCollection() {
            const btn = document.getElementById('refreshBtn');
            const icon = btn.querySelector('i');
            
            icon.classList.add('fa-spin');
            btn.disabled = true;
            
            socket.once('import_finished', (data) => {
                window.location.reload();
            });

            socket.once('import_error', (data) => {
                alert("import error: " + data.message);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            });
            try {
                const pseudo = "<%= user.discogsUsername %>";
                let fakeUrl = `https://www.discogs.com/user/${pseudo}`;
                
                const isWishlistPage = window.location.pathname.includes('wishlist');
                const type = isWishlistPage ? 'wishlist' : 'collection';

                const res = await fetch('/import/discogs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        discogsUrl: fakeUrl,
                        full: false,
                        type: type
                    })
                });

                if(!res.ok) {
                    socket.off('import_finished');
                    socket.off('import_error');
                    icon.classList.remove('fa-spin');
                    btn.disabled = false;
                }
            } catch(e) {
                console.error(e);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            }
        }
    <% } %>
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(100,100,100,0.2); border-radius: 2px; }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
</style>

<%- include('partials/footer') %>
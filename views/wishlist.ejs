<%- include('partials/header') %>

    <div class="max-w-screen-xl mx-auto px-1 md:px-0 pb-12">

        <div class="flex items-center justify-between mb-6 md:mb-8 pt-6">

            <h1 class="text-3xl font-bold flex flex-col md:flex-row md:items-center gap-2 md:gap-3 transition-colors truncate mr-4">
                <span class="flex items-center gap-2 md:gap-3 text-primary-theme">
                    <i class="fa-solid fa-gift flex-shrink-0"></i>
                    <span class="truncate">
                        Min ønskeliste
                    </span>
                </span>
                <span
                    class="px-3 md:mt-1.5 py-1 bg-black/5 dark:bg-white/10 rounded-full text-sm font-medium opacity-70 w-fit">
                    <%= albums.length %>
                        elementer
                </span>
            </h1>

        </div>

        <% if (albums.length===0) { %>
            <div
                class="text-center py-16 md:py-20 card-theme rounded-xl border-dashed opacity-80 transition-colors shadow-sm">
                <i class="fa-regular fa-heart text-5xl md:text-6xl opacity-20 mb-4 transition-colors"></i>
                <p class="opacity-60 px-4">
                    Din ønskeliste er tom.
                </p>
                <a href="<%= baseUrl %>/add-dvd"
                    class="text-primary-theme hover:underline mt-2 inline-block font-medium transition-colors">
                    Søg efter en film
                </a>
            </div>
            <% } else { %>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6">
                    <% albums.forEach(album=> { %>
                        <%
                            const isDvd = album.kind === 'Dvd' || (album.tmdb_id !== undefined && album.tmdb_id !== null);
                            const isGame = album.kind === 'Game';
                            const rawFormat = album.format || album.media_type;
                            const formatKey = rawFormat ? rawFormat.toLowerCase() : (isGame ? 'physical' : 'dvd');
                            let detailUrl = `/dvd/${album._id}`;
                            if (isGame) detailUrl = `/game/${album._id}`;
                            const badgeMap = {
                                'dvd': 'bg-sky-600/90', 'bluray': 'bg-indigo-700/90', '4k': 'bg-red-600/90',
                                'vhs': 'bg-amber-600/90', 'laserdisc': 'bg-purple-600/90',
                                'physical': 'bg-emerald-600/90', 'collector': 'bg-purple-600/90',
                                'limited': 'bg-pink-600/90', 'steelbook': 'bg-slate-600/90'
                            };
                            const badgeClass = (badgeMap[formatKey] || 'bg-gray-600/90') + ' text-white';
                        %>

                            <div
                                class="group relative card-theme rounded-xl hover:border-primary-theme transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
                                <a href="<%= baseUrl + detailUrl %>" class="block flex-grow">
                                    <div
                                        class="aspect-square w-full relative overflow-hidden bg-black/5 dark:bg-white/5 flex items-center justify-center">

                                        <img src="<%= album.cover_image %>"
                                            class="absolute inset-0 w-full h-full object-cover blur-xl opacity-30 scale-110 pointer-events-none">

                                        <img src="<%= album.cover_image %>"
                                            class="relative z-10 w-full h-full object-contain p-2 md:p-3 transition-transform duration-500 group-hover:scale-105"
                                            loading="lazy">

                                        <span
                                            class="absolute top-1.5 right-1.5 md:top-2 md:right-2 z-20 text-[10px] font-bold px-1.5 py-0.5 md:px-2 md:py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeClass %>">
                                            <% const _wlMediaLabels = { dvd: 'DVD', bluray: 'Blu-ray', '4k': '4K Ultra HD', vhs: 'VHS', laserdisc: 'Laserdisc', physical: 'Fysisk', collector: 'Samler', limited: 'Begrænset', steelbook: 'Steelbook' }; %>
                                            <%= _wlMediaLabels[formatKey] || formatKey %>
                                        </span>
                                    </div>

                                    <div class="p-3">
                                        <h3 class="font-bold text-xs md:text-sm truncate leading-tight mb-0.5"
                                            title="<%= album.title %>">
                                            <%= album.title %>
                                        </h3>
                                        <p class="text-[10px] md:text-xs opacity-60 truncate mb-2">
                                            <%= album.director || album.developer || '' %>
                                        </p>
                                    </div>
                                </a>

                                <% if (user.isAdmin) { %>
                                    <button onclick="moveToCollection('<%= album._id %>')"
                                        class="w-full py-2.5 md:py-2 bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white text-primary-theme text-[10px] md:text-xs font-bold uppercase transition-colors flex items-center justify-center gap-1.5 border-t border-black/10 dark:border-white/10 active:brightness-90">
                                        <i class="fa-solid fa-check"></i>
                                        <span>
                                            Jeg har modtaget den!
                                        </span>
                                    </button>
                                    <% } %>
                            </div>
                            <% }) %>
                </div>
                <% } %>
    </div>

    <script>
        const wishlistTranslations = {
            confirmMove: "Fedt! Vil du flytte dette album til din officielle samling?",
            serverError: "Der opstod en fejl. Prøv igen."
        };

        async function moveToCollection(id) {
            if (confirm(wishlistTranslations.confirmMove)) {
                try {
                    const res = await fetch(`<%= baseUrl %>/api/album/${id}/move-to-collection`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        window.location.reload();
                    }
                } catch (e) {
                    alert(wishlistTranslations.serverError);
                }
            }
        }
    </script>

    <%- include('partials/footer') %>

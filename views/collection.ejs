<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 md:px-0 pb-12">
    
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 pt-6 gap-4">
        
        <h1 class="text-3xl font-bold transition-colors">
            <%= t('collection.title') %> 
            <span class="opacity-60 text-lg font-normal transition-colors">
                (<%= albums.length %>)
            </span>
        </h1>

        <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">

            <div class="w-full sm:w-48">
                <input type="text" id="locationInput" list="locations-list" placeholder="<%= t('common.location') %>" class="block w-full p-2.5 text-sm card-theme rounded-lg border focus:ring-1 focus:ring-primary-theme focus:border-primary-theme outline-none transition-all placeholder-opacity-50">
                <datalist id="locations-list">
                    <% locations.forEach(loc => { %>
                        <option value="<%= loc %>"></option>
                    <% }) %>
                </datalist>
            </div>

            <div class="flex gap-2 w-full sm:w-auto">
                
                <div class="relative flex-grow sm:w-64">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <i class="fa-solid fa-search opacity-50 transition-colors"></i>
                    </div>
                    <input type="text" id="filterInput" class="block w-full p-2.5 pl-10 text-sm card-theme rounded-lg border focus:ring-1 focus:ring-primary-theme focus:border-primary-theme placeholder-opacity-50 transition-all" placeholder="<%= t('collection.filter_placeholder') %>">
                </div>

                <% if (user.isAdmin && user.discogsUsername) { %>
                    <button onclick="refreshCollection()" id="refreshBtn" class="flex-shrink-0 w-10 h-10 sm:w-auto sm:h-auto sm:px-4 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center active:scale-95 group" title="Rafraîchir depuis Discogs">
                        <i class="fa-solid fa-sync group-hover:rotate-180 transition-transform duration-500"></i>
                    </button>
                <% } %>

            </div>

        </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6" id="albumGrid">
        <% albums.forEach(album => { %>
            <div class="album-card group relative card-theme rounded-lg hover:border-primary-theme transition-all duration-300 hover:shadow-lg hover:-translate-y-1" 
                 data-location="<%= album.location || '' %>">
                
                <a href="/album/<%= album._id %>" class="block">
                    <div class="aspect-square w-full overflow-hidden rounded-t-lg relative">
                        <img src="<%= album.cover_image %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy">
                        
                        <% 
                            let mediatype = t('media.vinyl'); 
                            let badgeClass = "bg-green-600/90"; // Par défaut

                            if (album.media_type === 'cd') {
                                mediatype = t('media.cd');
                                badgeClass = "bg-blue-600/90";
                            } else if (album.media_type === 'cassette') {
                                mediatype = t('media.cassette');
                                badgeClass = "bg-orange-600/90";
                            }
                        %>
                        <span class="absolute bottom-2 left-2 text-white text-[10px] px-2 py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeClass %>">
                            <%= mediatype %>
                        </span>
                    </div>

                    <div class="p-3">
                        <h3 class="font-bold text-sm truncate transition-colors" title="<%= album.title %>"><%= album.title %></h3>
                        <p class="text-xs opacity-60 truncate mb-2 transition-colors"><%= album.artist %></p>
                        
                        <% if(album.variant_color) { %>
                            <div class="flex items-center gap-1">
                                <span class="w-2 h-2 rounded-full bg-primary-theme inline-block flex-shrink-0"></span>
                                <span class="text-[10px] opacity-60 truncate max-w-full"><%= album.variant_color %></span>
                            </div>
                        <% } %>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const filterInput = document.getElementById('filterInput');
    const locationInput = document.getElementById('locationInput');
    
    function applyFilters() {
        const term = filterInput.value.toLowerCase();
        const targetLoc = locationInput.value.toLowerCase().trim();
        
        document.querySelectorAll('.album-card').forEach(card => {
            const cardText = card.innerText.toLowerCase();
            const cardLoc = (card.getAttribute('data-location') || '').toLowerCase();            
            
            const matchesTerm = cardText.includes(term);
            const matchesLoc = targetLoc === '' || cardLoc.includes(targetLoc);

            card.style.display = (matchesTerm && matchesLoc) ? 'block' : 'none';
        });
    }

    if(filterInput) filterInput.addEventListener('keyup', applyFilters);
    if(locationInput) locationInput.addEventListener('input', applyFilters);

    <% if (user.isAdmin) { %>
        const socket = io();

        async function refreshCollection() {
            const btn = document.getElementById('refreshBtn');
            const icon = btn.querySelector('i');
            
            icon.classList.add('fa-spin');
            btn.disabled = true;
            
            socket.once('import_finished', (data) => {
                window.location.reload();
            });

            socket.once('import_error', (data) => {
                alert("import error: " + data.message);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            });
            try {
                const pseudo = "<%= user.discogsUsername %>";
                let fakeUrl = `https://www.discogs.com/user/${pseudo}`;
                
                const isWishlistPage = window.location.pathname.includes('wishlist');
                const type = isWishlistPage ? 'wishlist' : 'collection';

                const res = await fetch('/import/discogs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        discogsUrl: fakeUrl,
                        full: false,
                        type: type
                    })
                });

                if(!res.ok) {
                    socket.off('import_finished');
                    socket.off('import_error');
                    icon.classList.remove('fa-spin');
                    btn.disabled = false;
                }
            } catch(e) {
                console.error(e);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            }
        }
    <% } %>
</script>

<%- include('partials/footer') %>
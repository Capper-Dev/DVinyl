<%- include('partials/header') %>

<%
    const typeConfig = {
        dvd:   { label: 'Film & TV',      hint: 'film, serier og box sets' },
        games: { label: 'Spil',           hint: 'fysiske udgivelser og samleobjekter' },
        all:   { label: 'Hele samlingen', hint: 'alt du ejer fysisk' }
    };
    const tc = typeConfig[currentType] || typeConfig.all;

    const addRoutes = { dvd: '/add-dvd', games: '/add-game' };
    const addRoute  = addRoutes[currentType];

    const fmtLabels = { dvd: 'DVD', bluray: 'Blu-ray', '4k': '4K UHD', vhs: 'VHS', laserdisc: 'LD', physical: 'Fysisk', collector: 'Collector', limited: 'Limited', steelbook: 'Steelbook' };

    // Stats strip — show top 4 non-empty formats from the breakdown
    const statEntries = Object.entries(formatBreakdown || {})
        .filter(([k, v]) => k && k !== 'unknown' && v > 0)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 4);
%>

<div class="max-w-screen-xl mx-auto px-4 md:px-6 pb-20">

    <%# ───────── Page header ───────── %>
    <header class="pt-8 md:pt-14 pb-7">
        <p class="text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-sub mb-2.5">Din samling</p>
        <div class="flex items-end justify-between gap-4 flex-wrap">
            <div class="min-w-0">
                <h1 class="text-[32px] md:text-[56px] font-black leading-[0.95] tracking-tight truncate max-w-full"><%= tc.label %></h1>
                <p class="text-sub mt-2 text-[13px] md:text-base"><%= tc.hint %></p>
            </div>

            <% if (user.isAdmin && addRoute) { %>
            <a href="<%= baseUrl + addRoute %>"
               class="inline-flex items-center gap-2 bg-[var(--text-main)] text-[var(--bg-page)] text-[13px] font-bold px-4 py-2.5 md:px-5 md:py-3 rounded-full hover:opacity-90 active:scale-95 transition-all shrink-0">
                <i class="fa-solid fa-plus text-[11px]"></i>
                Tilføj
            </a>
            <% } %>
        </div>

        <%# Stats strip %>
        <div class="mt-6 flex items-baseline gap-x-4 gap-y-2 md:gap-x-7 flex-wrap text-sm">
            <span class="text-sub">
                <span class="text-[var(--text-main)] text-[22px] md:text-[28px] font-black tabular-nums tracking-tight"><%= libraryTotal || totalItems %></span>
                <span class="ml-1 text-[10px] md:text-xs font-semibold uppercase tracking-wider">titler</span>
            </span>
            <% statEntries.forEach(([key, count]) => { %>
            <a href="?type=<%= currentType %>&format=<%= key %>"
               class="text-sub hover:text-[var(--text-main)] transition-colors group whitespace-nowrap">
                <span class="text-[var(--text-main)] text-[16px] md:text-[20px] font-bold tabular-nums"><%= count %></span>
                <span class="ml-1 text-[10px] md:text-xs font-semibold uppercase tracking-wider group-hover:text-primary-theme transition-colors"><%= fmtLabels[key] || key %></span>
            </a>
            <% }) %>
        </div>
    </header>

    <%# ───────── Type tabs ───────── %>
    <%
        const tabTypes = [{ id: 'all', label: 'Alle' }];
        if (settings.modules.dvd)   tabTypes.push({ id: 'dvd',   label: 'Film & TV' });
        if (settings.modules.games) tabTypes.push({ id: 'games', label: 'Spil' });
    %>
    <nav class="border-b border-[var(--border-color)] mb-6">
        <div class="flex gap-6 -mb-px overflow-x-auto scrollbar-hide">
            <% tabTypes.forEach(tab => {
                const isActive = currentType === tab.id;
            %>
            <button type="button" onclick="switchType('<%= tab.id %>')"
                    class="relative py-3 text-[13px] font-semibold whitespace-nowrap transition-colors border-b-2
                    <%= isActive
                        ? 'border-[var(--text-main)] text-[var(--text-main)]'
                        : 'border-transparent text-sub hover:text-[var(--text-main)]' %>">
                <%= tab.label %>
            </button>
            <% }) %>
        </div>
    </nav>

    <%# ───────── Sticky toolbar ───────── %>
    <div class="sticky top-14 z-30 -mx-4 md:-mx-6 px-4 md:px-6 py-3 mb-5 surface-bg/95 backdrop-blur supports-[backdrop-filter]:bg-opacity-80 border-b border-[var(--border-color)]">
        <div class="flex flex-col sm:flex-row gap-2 sm:items-center">

            <div class="relative w-full sm:flex-grow min-w-0">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-sub text-[13px] pointer-events-none"></i>
                <input type="search" id="searchInput" value="<%= querySearch %>"
                       placeholder="Søg titel, år eller instruktør"
                       autocomplete="off"
                       class="w-full h-11 pl-11 pr-16 sm:pr-24 text-[14px] rounded-full bg-black/5 dark:bg-white/5 border border-transparent focus:bg-[var(--bg-card)] focus:border-[var(--border-color)] outline-none transition-all placeholder:text-sub">
                <kbd class="hidden sm:inline-flex absolute right-3 top-1/2 -translate-y-1/2 items-center gap-1 px-1.5 py-0.5 text-[10px] font-bold text-sub bg-black/5 dark:bg-white/5 rounded border border-[var(--border-color)]">
                    /
                </kbd>
                <% if (querySearch) { %>
                <button type="button" onclick="clearSearch()" aria-label="Ryd søgning"
                        class="absolute right-3 sm:right-12 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-sub hover:text-[var(--text-main)] hover:bg-black/10 dark:hover:bg-white/10 transition">
                    <i class="fa-solid fa-xmark text-[11px]"></i>
                </button>
                <% } %>
            </div>

            <div class="flex gap-2 w-full sm:w-auto">
                <% if (formatOptions && formatOptions.length > 0) { %>
                <div class="relative flex-1 sm:flex-none min-w-0">
                    <select id="formatSelect" onchange="applyFilters()"
                            class="appearance-none w-full sm:w-auto h-11 pl-4 pr-8 text-[13px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent hover:bg-black/10 dark:hover:bg-white/10 focus:border-[var(--border-color)] outline-none cursor-pointer transition truncate">
                        <option value="all">Alle formater</option>
                        <% formatOptions.forEach(opt => { %>
                        <option value="<%= opt.id %>" <%= currentFormat === opt.id ? 'selected' : '' %>><%= opt.label %></option>
                        <% }) %>
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-sub text-[9px] pointer-events-none"></i>
                </div>
                <% } %>

                <div class="relative flex-1 sm:flex-none min-w-0">
                    <select id="sortSelect" onchange="applyFilters()"
                            class="appearance-none w-full sm:w-auto h-11 pl-4 pr-8 text-[13px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent hover:bg-black/10 dark:hover:bg-white/10 focus:border-[var(--border-color)] outline-none cursor-pointer transition truncate">
                        <% const sortOpts = [
                            { v: 'added_desc', l: 'Nyest' },
                            { v: 'added_asc',  l: 'Ældst' },
                            { v: 'title_asc',  l: 'A–Z' },
                            { v: 'title_desc', l: 'Z–A' },
                            { v: 'year_desc',  l: 'Nyeste år' },
                            { v: 'year_asc',   l: 'Ældste år' }
                        ]; %>
                        <% sortOpts.forEach(o => { %>
                        <option value="<%= o.v %>" <%= currentSort === o.v ? 'selected' : '' %>><%= o.l %></option>
                        <% }) %>
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-sub text-[9px] pointer-events-none"></i>
                </div>
            </div>
        </div>
    </div>

    <%# ───────── Lists chips ───────── %>
    <% if (collectionsForType && collectionsForType.length > 0) { %>
    <div class="flex flex-wrap items-center gap-1.5 mb-6">
        <a href="?type=<%= currentType %><%= currentFormat !== 'all' ? '&format=' + currentFormat : '' %>"
           class="px-3 py-1.5 rounded-full text-[12px] font-semibold transition
                  <%= !activeCollectionId
                       ? 'bg-[var(--text-main)] text-[var(--bg-page)]'
                       : 'text-sub hover:text-[var(--text-main)] hover:bg-black/5 dark:hover:bg-white/5' %>">
            Alle
        </a>
        <a href="?type=<%= currentType %>&collection=uncategorized<%= currentFormat !== 'all' ? '&format=' + currentFormat : '' %>"
           class="px-3 py-1.5 rounded-full text-[12px] font-semibold transition
                  <%= activeCollectionId === 'uncategorized'
                       ? 'bg-[var(--text-main)] text-[var(--bg-page)]'
                       : 'text-sub hover:text-[var(--text-main)] hover:bg-black/5 dark:hover:bg-white/5' %>">
            Uden liste
        </a>
        <% collectionsForType.forEach(function(col) {
            const isActive = activeCollectionId && activeCollectionId.toString() === col._id.toString();
        %>
        <span class="inline-flex items-stretch rounded-full overflow-hidden text-[12px] font-semibold transition
                     <%= isActive
                          ? 'bg-[var(--text-main)] text-[var(--bg-page)]'
                          : 'text-sub hover:text-[var(--text-main)] bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10' %>">
            <a href="?type=<%= currentType %>&collection=<%= col._id %><%= currentFormat !== 'all' ? '&format=' + currentFormat : '' %>"
               class="px-3 py-1.5"><%= col.name %></a>
            <% if (user.isAdmin) { %>
            <button type="button" onclick="deleteCollection('<%= col._id %>', '<%= currentType %>')"
                    aria-label="Slet liste"
                    class="px-2 hover:bg-black/15 dark:hover:bg-white/10 transition">
                <i class="fa-solid fa-xmark text-[9px] opacity-70"></i>
            </button>
            <% } %>
        </span>
        <% }) %>
        <% if (user.isAdmin && ['dvd', 'games'].includes(currentType)) { %>
        <button type="button"
                onclick="document.getElementById('new-collection-modal').classList.remove('hidden')"
                class="px-3 py-1.5 rounded-full text-[12px] font-semibold text-sub hover:text-[var(--text-main)] border border-dashed border-[var(--border-color)] hover:border-[var(--text-main)] transition">
            <i class="fa-solid fa-plus text-[9px] mr-1"></i>Ny liste
        </button>
        <% } %>
    </div>
    <% } %>

    <%# ───────── Active filter pills ───────── %>
    <% if (querySearch || currentFormat !== 'all') { %>
    <div class="flex flex-wrap items-center gap-2 text-xs mb-5">
        <span class="text-sub">Aktive:</span>
        <% if (querySearch) { %>
        <button type="button" onclick="clearSearch()"
                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary-theme/15 text-primary-theme font-semibold hover:bg-primary-theme/25 transition">
            "<%= querySearch %>"
            <i class="fa-solid fa-xmark text-[9px]"></i>
        </button>
        <% } %>
        <% if (currentFormat !== 'all') { %>
        <button type="button" onclick="document.getElementById('formatSelect').value='all'; applyFilters();"
                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary-theme/15 text-primary-theme font-semibold hover:bg-primary-theme/25 transition">
            <%= fmtLabels[currentFormat] || currentFormat %>
            <i class="fa-solid fa-xmark text-[9px]"></i>
        </button>
        <% } %>
        <button type="button" onclick="clearAll()"
                class="text-sub hover:text-[var(--text-main)] underline underline-offset-2 ml-1">Ryd alle</button>
    </div>
    <% } %>

    <%# ───────── Grid ───────── %>
    <% if (albums.length === 0) { %>
    <div class="text-center py-28 border border-dashed border-[var(--border-color)] rounded-3xl">
        <i class="fa-regular fa-folder-open text-5xl opacity-15 mb-5 block"></i>
        <p class="font-bold text-lg mb-1.5">Ingenting her endnu</p>
        <p class="text-sub text-sm mb-7">
            <% if (querySearch || currentFormat !== 'all') { %>
                Prøv at justere dine filtre.
            <% } else { %>
                Start med at tilføje dit første element.
            <% } %>
        </p>
        <% if (querySearch || currentFormat !== 'all') { %>
        <button type="button" onclick="clearAll()"
                class="text-[13px] font-bold text-primary-theme hover:underline">
            Ryd filtre
        </button>
        <% } else if (user.isAdmin && addRoute) { %>
        <a href="<%= baseUrl + addRoute %>"
           class="inline-flex items-center gap-2 bg-[var(--text-main)] text-[var(--bg-page)] text-[13px] font-bold px-5 py-3 rounded-full hover:opacity-90 transition">
            <i class="fa-solid fa-plus text-[11px]"></i>
            Tilføj det første
        </a>
        <% } %>
    </div>
    <% } else { %>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7 gap-x-3 gap-y-6 md:gap-x-5 md:gap-y-8">
        <% albums.forEach(album => {
            const isGame = album.kind === 'Game';
            const detailUrl = isGame ? '/game/' + album._id : '/dvd/' + album._id;
            const formatKey = (album.format || '').toLowerCase();
            const displayFormat = isGame ? (album.platform || fmtLabels[formatKey] || 'Spil') : (fmtLabels[formatKey] || formatKey || 'Film');
            const subtitle = isGame ? (album.developer || album.publisher || '') : (album.director || '');
        %>
        <a href="<%= baseUrl + detailUrl %>" class="group block">
            <div class="relative aspect-[2/3] overflow-hidden rounded-md bg-black/5 dark:bg-white/5 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_20px_40px_-12px_rgba(0,0,0,0.35)]">
                <%# Ambient glow from poster %>
                <img src="<%= album.cover_image %>" alt="" aria-hidden="true"
                     class="absolute inset-0 w-full h-full object-cover blur-2xl opacity-25 scale-110 pointer-events-none">

                <img src="<%= album.cover_image %>" alt="<%= album.title %>"
                     loading="lazy"
                     class="relative z-10 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]">

                <%# Overlay on hover with format chip %>
                <div class="absolute inset-0 z-20 flex items-end p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-t from-black/70 via-black/10 to-transparent">
                    <span class="text-[10px] font-bold text-white px-2 py-0.5 rounded backdrop-blur-md bg-black/40 border border-white/15">
                        <%= displayFormat %>
                    </span>
                </div>
            </div>
            <div class="mt-2.5 px-0.5">
                <p class="text-[13px] font-semibold leading-tight truncate text-[var(--text-main)]" title="<%= album.title %>"><%= album.title %></p>
                <% if (album.year || subtitle) { %>
                <p class="text-[11px] text-sub truncate mt-1 tabular-nums">
                    <% if (album.year) { %><%= album.year %><% } %>
                    <% if (album.year && subtitle) { %><span class="opacity-50"> · </span><% } %>
                    <% if (subtitle) { %><span class="font-normal tabular-nums-off"><%= subtitle %></span><% } %>
                </p>
                <% } %>
            </div>
        </a>
        <% }) %>
    </div>
    <% } %>

    <%# ───────── Pagination ───────── %>
    <% if (albums.length > 0 && totalPages > 1) { %>
    <div class="mt-14 pt-7 border-t border-[var(--border-color)] flex flex-col-reverse md:flex-row items-center justify-between gap-5">

        <div class="flex items-center gap-2 text-[12px] text-sub">
            <span class="font-semibold uppercase tracking-wider">Vis</span>
            <div class="inline-flex bg-black/5 dark:bg-white/5 p-1 rounded-full">
                <% [25, 50, 100].forEach(num => { %>
                <button type="button" onclick="setLimit(<%= num %>)"
                    class="px-2.5 py-1 text-[12px] font-bold rounded-full transition tabular-nums
                    <%= (queryLimit == num)
                        ? 'bg-[var(--text-main)] text-[var(--bg-page)]'
                        : 'text-sub hover:text-[var(--text-main)]' %>">
                    <%= num %>
                </button>
                <% }) %>
            </div>
        </div>

        <nav aria-label="Sider" class="flex items-center gap-0.5 sm:gap-1 max-w-full overflow-x-auto scrollbar-hide">
            <button type="button" onclick="changePage(<%= currentPage - 1 %>)" <%= currentPage <= 1 ? 'disabled' : '' %>
                aria-label="Forrige"
                class="shrink-0 w-8 h-8 sm:w-9 sm:h-9 flex items-center justify-center rounded-full text-sub hover:text-[var(--text-main)] hover:bg-black/5 dark:hover:bg-white/5 transition disabled:opacity-20 disabled:pointer-events-none">
                <i class="fa-solid fa-chevron-left text-[11px]"></i>
            </button>

            <% for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
            %>
            <button type="button" onclick="changePage(<%= i %>)"
                class="shrink-0 w-8 h-8 sm:w-9 sm:h-9 flex items-center justify-center rounded-full text-[12px] sm:text-[13px] font-bold transition tabular-nums
                <%= currentPage === i
                    ? 'bg-[var(--text-main)] text-[var(--bg-page)]'
                    : 'text-sub hover:text-[var(--text-main)] hover:bg-black/5 dark:hover:bg-white/5' %>">
                <%= i %>
            </button>
            <%   } else if (i === currentPage - 2 || i === currentPage + 2) { %>
            <span class="shrink-0 px-1 text-sub opacity-50">…</span>
            <%   } } %>

            <button type="button" onclick="changePage(<%= currentPage + 1 %>)" <%= currentPage >= totalPages ? 'disabled' : '' %>
                aria-label="Næste"
                class="shrink-0 w-8 h-8 sm:w-9 sm:h-9 flex items-center justify-center rounded-full text-sub hover:text-[var(--text-main)] hover:bg-black/5 dark:hover:bg-white/5 transition disabled:opacity-20 disabled:pointer-events-none">
                <i class="fa-solid fa-chevron-right text-[11px]"></i>
            </button>
        </nav>
    </div>
    <% } %>
</div>

<%# New list modal %>
<% if (user.isAdmin) { %>
<div id="new-collection-modal" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center bg-black/60 backdrop-blur-sm sm:p-4">
    <div class="surface-card w-full max-w-sm rounded-t-3xl sm:rounded-3xl p-6 shadow-2xl border border-[var(--border-color)]">
        <div class="w-10 h-1 bg-black/10 dark:bg-white/10 rounded-full mx-auto mb-5 sm:hidden"></div>
        <h3 class="text-lg font-black mb-1">Ny liste</h3>
        <p class="text-xs text-sub mb-4">Grupper relaterede elementer (fx en samling eller en instruktørs film).</p>
        <input id="new-collection-name" type="text" placeholder="Fx Marvel-film"
               class="w-full bg-black/5 dark:bg-white/5 border border-transparent focus:border-[var(--text-main)] rounded-xl px-4 py-3 text-sm mb-4 focus:outline-none transition-colors">
        <div class="flex gap-2">
            <button type="button" onclick="document.getElementById('new-collection-modal').classList.add('hidden')"
                    class="flex-1 py-3 text-sm font-bold rounded-xl bg-black/5 dark:bg-white/5 text-sub hover:text-[var(--text-main)] transition">Annullér</button>
            <button type="button" onclick="createCollection()"
                    class="flex-1 py-3 text-sm font-bold rounded-xl bg-[var(--text-main)] text-[var(--bg-page)] hover:opacity-90 active:scale-95 transition">Opret</button>
        </div>
    </div>
</div>
<% } %>

<script>
    function buildUrl(overrides = {}) {
        const url = new URL(window.location.origin + window.location.pathname);
        const searchVal = (document.getElementById('searchInput')?.value || '').trim();
        const formatVal = document.getElementById('formatSelect')?.value || 'all';
        const sortVal   = document.getElementById('sortSelect')?.value   || 'added_desc';

        const final = {
            type:       '<%= currentType %>',
            format:     formatVal,
            search:     searchVal,
            sort:       sortVal,
            limit:      '<%= queryLimit %>',
            collection: '<%= activeCollectionId || "" %>',
            page:       '1',
            ...overrides
        };
        Object.entries(final).forEach(([k, v]) => {
            if (v === '' || v === 'all' || v == null) return;
            url.searchParams.set(k, v);
        });
        return url.toString();
    }

    function applyFilters() { window.location.href = buildUrl(); }
    function switchType(t) { window.location.href = buildUrl({ type: t, format: 'all', collection: '' }); }
    function setLimit(n)   { window.location.href = buildUrl({ limit: n }); }
    function changePage(p) { if (p < 1) return; window.location.href = buildUrl({ page: p }); }

    function clearSearch() {
        const input = document.getElementById('searchInput');
        if (input) input.value = '';
        applyFilters();
    }
    function clearAll() {
        const input = document.getElementById('searchInput');
        const fmt   = document.getElementById('formatSelect');
        if (input) input.value = '';
        if (fmt)   fmt.value = 'all';
        applyFilters();
    }

    // Debounced search-on-type
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        let t;
        searchInput.addEventListener('input', () => {
            clearTimeout(t);
            t = setTimeout(applyFilters, 400);
        });
        searchInput.addEventListener('keydown', e => {
            if (e.key === 'Enter') { e.preventDefault(); clearTimeout(t); applyFilters(); }
            if (e.key === 'Escape') { e.target.blur(); }
        });
    }

    // Keyboard: "/" focuses search
    document.addEventListener('keydown', e => {
        if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
            e.preventDefault();
            searchInput?.focus();
            searchInput?.select();
        }
    });

    <% if (user.isAdmin) { %>
    async function deleteCollection(id, type) {
        if (!confirm('Slet denne liste? Elementer mister listetilknytningen.')) return;
        const res = await fetch('<%= baseUrl %>/api/collections/' + id, { method: 'DELETE' });
        if (res.ok) window.location.href = '?type=' + type;
        else alert('Kunne ikke slette liste.');
    }
    async function createCollection() {
        const name = document.getElementById('new-collection-name').value.trim();
        const type = '<%= currentType === "games" ? "game" : "dvd" %>';
        if (!name) return;
        const res = await fetch('<%= baseUrl %>/api/collections', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, type })
        });
        if (res.ok) window.location.reload();
        else alert('Kunne ikke oprette liste.');
    }
    <% } %>
</script>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-16 px-4 md:px-6 space-y-10">

    <section class="pt-8 pb-2">
        <div class="flex items-end justify-between mb-1">
            <div>
                <h1 class="text-3xl md:text-4xl font-black tracking-tight leading-none">Collection</h1>
                <p class="opacity-40 text-sm mt-1"><%= stats.total %> items</p>
            </div>
            <button onclick="toggleAddModal()" class="flex items-center gap-2 bg-primary-theme text-white text-sm font-bold px-4 py-2.5 rounded-xl hover:brightness-110 transition-all active:scale-95 shadow-lg shadow-primary-theme/20">
                <i class="fa-solid fa-plus"></i>
                <span class="hidden sm:inline">Add</span>
            </button>
        </div>

        <div class="flex gap-3 mt-6">
            <% if (settings.modules.dvd) { %>
            <a href="<%= baseUrl %>/collection?type=dvd" class="flex-1 card-theme rounded-2xl p-4 hover:border-primary-theme transition-all group text-center">
                <i class="fa-solid fa-film text-xl opacity-50 group-hover:opacity-100 group-hover:text-primary-theme transition-all mb-2 block"></i>
                <div class="text-2xl font-black"><%= stats.dvd_total || 0 %></div>
                <div class="text-xs opacity-40 font-medium mt-0.5">Movies</div>
            </a>
            <% } %>
            <% if (settings.modules.games) { %>
            <a href="<%= baseUrl %>/collection?type=games" class="flex-1 card-theme rounded-2xl p-4 hover:border-primary-theme transition-all group text-center">
                <i class="fa-solid fa-gamepad text-xl opacity-50 group-hover:opacity-100 group-hover:text-primary-theme transition-all mb-2 block"></i>
                <div class="text-2xl font-black"><%= stats.game_total || 0 %></div>
                <div class="text-xs opacity-40 font-medium mt-0.5">Games</div>
            </a>
            <% } %>
        </div>
    </section>

    <section>
        <h2 class="text-base font-bold opacity-50 uppercase tracking-widest mb-4">Recently Added</h2>

        <% if (recentItems && recentItems.length > 0) { %>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3">
            <% recentItems.forEach(album => { %>
            <%
                const isDvd  = album.kind === 'Dvd' || (album.tmdb_id !== undefined && album.tmdb_id !== null);
                const isGame = album.kind === 'Game';
                let detailUrl = `/dvd/${album._id}`;
                if (isGame) detailUrl = `/game/${album._id}`;
            %>
            <a href="<%= baseUrl + detailUrl %>" class="group relative">
                <div class="aspect-[2/3] rounded-xl overflow-hidden bg-black/5 dark:bg-white/5 shadow-sm group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300">
                    <img src="<%= album.cover_image %>" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-20 scale-110 pointer-events-none">
                    <img src="<%= album.cover_image %>"
                         class="relative z-10 w-full h-full object-contain p-1 transition-transform duration-500 group-hover:scale-105"
                         loading="lazy">
                </div>
                <p class="text-xs font-semibold truncate mt-1.5 opacity-80"><%= album.title %></p>
            </a>
            <% }) %>
        </div>
        <% } else { %>
        <div class="text-center py-16 card-theme rounded-2xl">
            <i class="fa-solid fa-box-open text-4xl opacity-20 mb-3 block"></i>
            <p class="opacity-40 text-sm">Nothing here yet. Start adding items.</p>
        </div>
        <% } %>
    </section>
</div>

<div id="addHubModal" class="fixed inset-0 z-[100] hidden bg-black/60 backdrop-blur-sm flex items-end sm:items-center justify-center sm:p-4">
    <%
        let activeCount = 0;
        if (settings.modules.dvd)    activeCount++;
        if (settings.modules.games)  activeCount++;
        let gridCols = activeCount === 1 ? 'grid-cols-1' : 'grid-cols-2';
        let desktopGridCols = activeCount >= 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2';
        let maxWidth = activeCount === 1 ? 'max-w-sm' : 'max-w-md';
    %>
    <div class="card-theme w-full <%= maxWidth %> rounded-t-3xl sm:rounded-3xl p-6 sm:p-8 shadow-2xl relative">
        <div class="w-10 h-1 bg-black/10 dark:bg-white/10 rounded-full mx-auto mb-6 sm:hidden"></div>
        <button onclick="toggleAddModal()" class="absolute top-5 right-5 opacity-30 hover:opacity-80 transition-opacity hidden sm:block">
            <i class="fa-solid fa-xmark text-xl"></i>
        </button>
        <h2 class="text-xl font-black mb-6">Add to collection</h2>
        <div class="grid <%= gridCols %> <%= desktopGridCols %> gap-3">
            <% if (settings.modules.dvd) { %>
            <a href="<%= baseUrl %>/add-dvd" class="group flex items-center gap-3 p-4 rounded-2xl bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white transition-all">
                <i class="fa-solid fa-film text-lg opacity-60 group-hover:opacity-100"></i>
                <span class="font-bold text-sm">Movie / TV</span>
            </a>
            <% } %>
            <% if (settings.modules.games) { %>
            <a href="<%= baseUrl %>/add-game" class="group flex items-center gap-3 p-4 rounded-2xl bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white transition-all">
                <i class="fa-solid fa-gamepad text-lg opacity-60 group-hover:opacity-100"></i>
                <span class="font-bold text-sm">Game</span>
            </a>
            <% } %>
        </div>
        <button onclick="toggleAddModal()" class="w-full mt-4 py-3 bg-black/5 dark:bg-white/5 rounded-xl font-bold text-sm sm:hidden opacity-50">
            Cancel
        </button>
    </div>
</div>

<script>
    function toggleAddModal() {
        const modal = document.getElementById('addHubModal');
        modal.classList.toggle('hidden');
    }
    document.getElementById('addHubModal').addEventListener('click', function(e) {
        if (e.target === this) toggleAddModal();
    });
</script>

<%- include('partials/footer') %>

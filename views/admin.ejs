<%- include('partials/header') %>

    <div class="max-w-screen-xl mx-auto px-4 pb-20 space-y-10">

        <div class="flex flex-col sm:flex-row sm:items-center justify-between py-6 gap-4">
            <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
                <i class="fa-solid fa-shield-halved text-primary-theme"></i>
                Administration
            </h1>
            <div
                class="w-fit text-[10px] font-black tracking-widest opacity-40 border border-black/10 dark:border-white/10 px-3 py-1 rounded-full">
                v<%= appVersion %>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
                <i class="fa-solid fa-puzzle-piece text-primary-theme"></i>
                Moduler
            </h1>
        </div>

        <section class="card-theme rounded-3xl p-6 shadow-sm mb-10 transition-colors">
            <div class="flex flex-col gap-8">
                <div class="flex items-center gap-4">
                    <div
                        class="w-12 h-12 rounded-2xl bg-primary-theme/10 text-primary-theme flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-cubes-stacked text-xl"></i>
                    </div>
                    <div>
                        <h2 class="text-sm font-black uppercase tracking-widest opacity-80">
                            Aktive moduler
                        </h2>
                        <p class="text-xs opacity-50">
                            Aktivér eller deaktivér DVinyls moduler
                        </p>
                    </div>
                </div>

                <form action="<%= baseUrl %>/admin/modules/save" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                        <% const mods=[ {key: 'dvd' , label: "DVD'er", icon: 'fa-film' , needsKey: true},
                            {key: 'games' , label: 'Videospil', icon: 'fa-gamepad' , needsKey: true} ] %>
                            <% mods.forEach((mod)=> { %>
                                <div class="flex flex-col gap-2">
                                    <label
                                        class="group flex items-center justify-between p-4 rounded-2xl bg-black/5 dark:bg-white/5 border border-transparent hover:border-primary-theme/30 has-[:checked]:bg-green-500/10 has-[:checked]:border-green-500/30 transition-all cursor-pointer">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="w-10 h-10 rounded-xl flex items-center justify-center bg-white dark:bg-black/20 shadow-sm group-hover:text-primary-theme group-has-[:checked]:bg-green-500 group-has-[:checked]:text-white transition-colors">
                                                <i class="fa-solid <%= mod.icon %> text-sm"></i>
                                            </div>
                                            <span
                                                class="text-sm font-bold opacity-70 group-hover:opacity-100 group-has-[:checked]:opacity-100 transition-opacity">
                                                <%= mod.label %>
                                            </span>
                                        </div>
                                        <div class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" name="<%= mod.key %>Active" <%=settings.modules &&
                                                settings.modules[mod.key] ? 'checked' : '' %> class="sr-only peer">
                                            <div
                                                class="w-11 h-6 bg-black/10 dark:bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500">
                                            </div>
                                        </div>
                                    </label>
                                    <% if (mod.needsKey) { %>
                                        <div id="error-<%= mod.key %>"
                                            class="hidden p-3 bg-red-500/10 border border-red-500/20 rounded-xl animate-in fade-in slide-in-from-top-1 duration-300">
                                            <p class="text-[10px] text-red-500 font-bold flex items-center gap-2">
                                                <i class="fa-solid fa-circle-exclamation"></i>
                                                Kan ikke aktivere dette modul: API-nøglen mangler.
                                            </p>
                                            <a href="https://github.com/Kyonew/DVinyl/blob/main/docs/api-keys.md"
                                                target="_blank"
                                                class="text-[9px] text-primary-theme underline mt-1 block font-bold uppercase tracking-tighter">
                                                Læs konfigurationsvejledningen
                                            </a>
                                        </div>
                                        <% } %>
                                </div>
                                <% }) %>
                    </div>
                    <div class="flex justify-end pt-2">
                        <button type="submit"
                            class="w-full sm:w-auto bg-primary-theme text-white text-xs font-black uppercase tracking-widest px-10 py-4 rounded-2xl hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary-theme/20 flex items-center justify-center gap-3">
                            <i class="fa-solid fa-save"></i>
                            Gem præferencer
                        </button>
                    </div>
                </form>
            </div>
        </section>

        <% if (locals.newPassword) { %>
            <div
                class="bg-primary-theme/10 border border-primary-theme/30 p-6 rounded-2xl text-center animate-pulse transition-colors">
                <h2 class="text-lg font-bold text-primary-theme mb-2">
                    <i class="fa-solid fa-check-circle"></i>
                    <%= successMessage %>
                </h2>
                <p class="text-sm opacity-70 mb-4">
                    Her er den midlertidige adgangskode (kopiér den, den vises ikke igen):
                </p>
                <div
                    class="bg-white dark:bg-black/50 p-4 rounded-xl inline-flex items-center gap-3 border border-primary-theme/30 shadow-sm overflow-hidden max-w-full">
                    <code class="text-xl md:text-2xl font-mono select-all break-all"><%= newPassword %></code>
                </div>
            </div>
            <% } %>
            
                <%- include('partials/admin-visibility') %>

                <section>
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between py-6 gap-4 mb-4">
                        <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
                            <i class="fa-solid fa-users text-neutral-400 dark:text-neutral-500"></i>
                            Brugere (<%= users.length %>)
                        </h1>
                        <button onclick="toggleModal('addUserModal')"
                            class="group relative flex items-center gap-3 bg-primary-theme hover:brightness-110 text-white px-5 py-3 rounded-2xl shadow-lg shadow-primary-theme/20 transition-all active:scale-95 overflow-hidden">
                            <div
                                class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform">
                            </div>
                            <i class="fa-solid fa-user-plus text-sm relative"></i>
                            <span class="text-xs font-black relative">
                                Ny bruger
                            </span>
                        </button>
                    </div>

                    <div class="hidden md:block card-theme rounded-2xl overflow-hidden shadow-lg transition-colors">
                        <table class="w-full text-left text-sm opacity-80">
                            <thead class="bg-black/5 dark:bg-white/5 text-xs uppercase opacity-70 transition-colors">
                                <tr>
                                    <th class="px-6 py-4">
                                        Bruger
                                    </th>
                                    <th class="px-6 py-4">
                                        E-mail
                                    </th>
                                    <th class="px-6 py-4">
                                        Sidste ændring
                                    </th>
                                    <th class="px-6 py-4 text-right">
                                        Handlinger
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-black/5 dark:divide-white/5 transition-colors">
                                <% users.forEach(u=> { %>
                                    <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                                        <td class="px-6 py-4 font-medium flex items-center gap-3">
                                            <img src="<%= baseUrl + u.img %>"
                                                class="w-8 h-8 rounded-full border border-black/10 dark:border-white/10 object-cover">
                                            <%= u.username %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <%= u.email %>
                                        </td>
                                        <td class="px-6 py-4 text-xs opacity-70">
                                            <%= new Date(u.lastChange).toLocaleDateString('da-DK') %>
                                        </td>
                                        <td class="px-6 py-4 text-right flex justify-end gap-2">
                                            <form action="<%= baseUrl %>/admin/reset-password" method="POST"
                                                onsubmit="return confirm('<%= `Nulstil adgangskode for ${u.username}?` %>')">
                                                <input type="hidden" name="userId" value="<%= u._id %>">
                                                <button type="submit"
                                                    class="text-yellow-600 bg-yellow-100 dark:bg-yellow-500/10 p-2 rounded-lg transition-colors hover:brightness-110"
                                                    title="Nulstil adgangskode">
                                                    <i class="fa-solid fa-key"></i>
                                                </button>
                                            </form>
                                            <% if (u._id.toString() !==user._id.toString()) { %>
                                                <form action="<%= baseUrl %>/admin/delete-user" method="POST"
                                                    onsubmit="return confirm('<%= `SLET ${u.username} PERMANENT?` %>')">
                                                    <input type="hidden" name="userId" value="<%= u._id %>">
                                                    <button type="submit"
                                                        class="text-red-600 bg-red-100 dark:bg-red-500/10 p-2 rounded-lg transition-colors hover:brightness-110"
                                                        title="Slet">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                </form>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="md:hidden space-y-4">
                        <% users.forEach(u=> { %>
                            <div class="card-theme p-5 rounded-2xl shadow-sm space-y-4 transition-colors">
                                <div class="flex items-center gap-4">
                                    <img src="<%= baseUrl + u.img %>"
                                        class="w-12 h-12 rounded-full border border-black/10 dark:border-white/10 object-cover">
                                    <div class="overflow-hidden">
                                        <p class="font-bold truncate">
                                            <%= u.username %>
                                        </p>
                                        <p class="text-xs opacity-60 truncate">
                                            <%= u.email %>
                                        </p>
                                    </div>
                                </div>
                                <div
                                    class="flex items-center justify-between pt-4 border-t border-black/5 dark:border-white/5">
                                    <div class="flex flex-col">
                                        <span class="text-[9px] opacity-50 uppercase font-bold tracking-wider">
                                            Sidste ændring
                                        </span>
                                        <span class="text-xs opacity-70">
                                            <%= new Date(u.lastChange).toLocaleDateString('da-DK') %>
                                        </span>
                                    </div>
                                    <div class="flex gap-2">
                                        <form action="<%= baseUrl %>/admin/reset-password" method="POST"
                                            onsubmit="return confirm('<%= `Nulstil adgangskode for ${u.username}?` %>')">
                                            <input type="hidden" name="userId" value="<%= u._id %>">
                                            <button type="submit"
                                                class="text-yellow-600 bg-yellow-50 dark:bg-yellow-500/10 px-4 py-2 rounded-xl border border-yellow-200 dark:border-yellow-500/20 text-sm font-bold">
                                                <i class="fa-solid fa-key"></i>
                                            </button>
                                        </form>
                                        <% if (u._id.toString() !==user._id.toString()) { %>
                                            <form action="<%= baseUrl %>/admin/delete-user" method="POST"
                                                onsubmit="return confirm('<%= `SLET ${u.username} PERMANENT?` %>')">
                                                <input type="hidden" name="userId" value="<%= u._id %>">
                                                <button type="submit"
                                                    class="text-red-600 bg-red-50 dark:bg-red-500/10 px-4 py-2 rounded-xl border border-red-200 dark:border-red-500/20 text-sm font-bold">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                            <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </section>

                <section>
                    <div class="flex items-center gap-4 mb-6">
                        <h2 class="text-lg sm:text-xl font-bold flex items-center gap-2 whitespace-nowrap">
                            <i class="fa-solid fa-clock-rotate-left text-red-500"></i>
                            Slet seneste elementer
                        </h2>
                        <div class="flex-grow border-t border-black/10 dark:border-white/10"></div>
                    </div>

                    <p class="text-sm opacity-50 -mt-2 mb-6">
                        Nyttigt efter en mislykket import. Sletter de N seneste elementer af den valgte type.
                    </p>

                    <div class="card-theme rounded-3xl p-5 sm:p-8 shadow-sm">

                        <div class="flex flex-col gap-6 sm:flex-row sm:items-end">

                            <div class="flex-1 space-y-2">
                                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50">
                                    Elementtype
                                </label>
                                <select id="deleteKind"
                                    class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                    <% if (settings.modules.dvd) { %>
                                        <option class="bg-white dark:bg-[#1a1a1a]" value="Dvd">
                                            DVD'er
                                        </option>
                                    <% } %>
                                    <% if (settings.modules.games) { %>
                                        <option class="bg-white dark:bg-[#1a1a1a]" value="Game">
                                            Videospil
                                        </option>
                                    <% } %>
                                </select>
                            </div>

                            <div class="flex-1 space-y-2">
                                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50">
                                    Antal at slette
                                </label>
                                <input type="number" id="deleteCount" min="1" placeholder="ex: 500"
                                    class="w-full bg-black/5 dark:bg-white/5 rounded-xl p-3 text-sm outline-none focus:ring-2 focus:ring-red-500/30">
                            </div>

                            <button onclick="confirmDeleteLast()" class="w-full sm:w-auto flex items-center justify-center gap-2
                            bg-red-500/10 hover:bg-red-500
                            text-red-500 hover:text-white
                            border border-red-500/20 hover:border-red-500
                            font-black px-6 py-3 rounded-xl
                            transition-all active:scale-95">
                                <i class="fa-solid fa-trash"></i>
                                Slet
                            </button>
                        </div>

                        <div id="deleteLastError" class="hidden mt-6 bg-red-500/10 border border-red-500/20
                        text-red-400 p-4 rounded-xl text-sm flex gap-3">
                            <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
                            <span id="deleteLastErrorText" class="leading-relaxed"></span>
                        </div>

                        <div id="deleteLastSuccess" class="hidden mt-6 bg-green-500/10 border border-green-500/20
                        text-green-400 p-4 rounded-xl text-sm flex gap-3">
                            <i class="fa-solid fa-check-circle mt-0.5"></i>
                            <span id="deleteLastSuccessText" class="leading-relaxed"></span>
                        </div>

                    </div>
                </section>

                <section>
                    <div class="flex items-center gap-4 mb-6">
                        <h2 class="text-xl font-bold flex items-center gap-2 transition-colors whitespace-nowrap">
                            <i class="fa-solid fa-database text-primary-theme"></i>
                            Database-backup
                        </h2>
                        <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
                    </div>
                    <p class="text-sm opacity-50 -mt-3 mb-6">
                        Eksportér eller gendan hele din samling.
                    </p>

                    <div class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div>
                                <h2 class="text-xl font-bold flex items-center gap-2 mb-2">
                                    <i class="fa-solid fa-database text-primary-theme"></i>
                                    Systemvedligeholdelse
                                </h2>
                                <p class="text-sm opacity-60">
                                    Sikkerhedskopiér din samling eller gendan en eksisterende database.
                                </p>
                            </div>
                            <div class="flex flex-wrap gap-3">
                                <a href="<%= baseUrl %>/backup/export"
                                    class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-file-export"></i>
                                    Eksportér database
                                </a>
                                <label
                                    class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-yellow-500 hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 cursor-pointer">
                                    <i class="fa-solid fa-file-import"></i>
                                    Importér database
                                        <input type="file" id="backupInput" class="hidden" accept=".json">
                                </label>
                            </div>
                        </div>
                    </div>
                </section>

                <section>
                    <div class="flex items-center gap-4 mb-6">
                        <h2 class="text-xl font-bold flex items-center gap-2 transition-colors whitespace-nowrap">
                            <i class="fa-solid fa-wrench text-primary-theme"></i>
                            Vedligeholdelse
                        </h2>
                        <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
                    </div>
                    <p class="text-sm opacity-50 -mt-3 mb-6">
                        Global håndtering af dine samlingers metadata.
                    </p>

                    <% if (false) { %>
                        <!-- Books Refresh Block -->
                        <div class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors mb-6">
                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                                <div class="max-w-xl">
                                    <h2 class="text-lg font-bold flex items-center gap-2 mb-2">
                                        <i class="fa-solid fa-book text-[#553B08] dark:text-yellow-600"></i>
                                        Opdater al metadata (bøger)
                                    </h2>
                                    <p class="text-xs opacity-60 leading-relaxed mb-4">
                                        Genstart dataindhentning (Hardcover/OpenLibrary) for bøger.
                                    </p>
                                    <div class="flex flex-col gap-2 max-w-xs">
                                        <label
                                            class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1">
                                            Opdateringstilstand
                                        </label>
                                        <select id="refreshModeBook"
                                            class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                            <option class="bg-white dark:bg-[#1a1a1a]" value="all">
                                                Alle elementer (langsom)
                                            </option>
                                            <option class="bg-white dark:bg-[#1a1a1a]" value="missing" selected>
                                                Kun elementer med manglende genrer/stilarter (hurtigst)
                                            </option>
                                        </select>
                                    </div>
                                </div>
                                <div>
                                    <button id="btnRefreshBook" onclick="startMetadataRefresh('Book')"
                                        class="w-full sm:w-auto bg-black/5 dark:bg-white/5 hover:bg-yellow-600 hover:text-white px-8 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 border border-black/10 dark:border-white/10 shadow-sm">
                                        <i class="fa-solid fa-play" id="iconRefreshBook"></i>
                                        <span id="textRefreshBook">
                                            Start opdatering
                                        </span>
                                    </button>
                                </div>
                            </div>
                            <div id="progressContainerBook"
                                class="hidden mt-6 space-y-3 p-4 bg-black/5 dark:bg-white/5 rounded-2xl animate-in fade-in slide-in-from-top-2 duration-500">
                                <div
                                    class="flex justify-between items-center text-[10px] uppercase font-bold tracking-widest opacity-60">
                                    <span id="progressTitleBook">
                                        Initialiserer...
                                    </span>
                                    <span id="progressPercentBook">0%</span>
                                </div>
                                <div class="w-full bg-black/10 dark:bg-white/10 rounded-full h-2 overflow-hidden">
                                    <div id="progressBarBook"
                                        class="bg-yellow-500 h-full transition-all duration-300 w-0"></div>
                                </div>
                                <p id="progressItemBook" class="text-[10px] opacity-40 font-mono truncate"></p>
                            </div>
                        </div>
                        <% } %>

                            <% if (settings.modules.dvd) { %>
                                <!-- DVDs Refresh Block -->
                                <div class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors mb-6">
                                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                                        <div class="max-w-xl">
                                            <h2 class="text-lg font-bold flex items-center gap-2 mb-2">
                                                <i class="fa-solid fa-film text-purple-600"></i>
                                                Opdater al metadata (DVD'er)
                                            </h2>
                                            <p class="text-xs opacity-60 leading-relaxed mb-4">
                                                Genstart dataindhentning (TMDB) for DVD'er og Blu-Rays.
                                            </p>
                                            <div class="flex flex-col gap-2 max-w-xs">
                                                <label
                                                    class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1">
                                                    Opdateringstilstand
                                                </label>
                                                <select id="refreshModeDvd"
                                                    class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                                    <option class="bg-white dark:bg-[#1a1a1a]" value="all">
                                                        Alle elementer (langsom)
                                                    </option>
                                                    <option class="bg-white dark:bg-[#1a1a1a]" value="missing" selected>
                                                        Kun elementer med manglende genrer/stilarter (hurtigst)
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div>
                                            <button id="btnRefreshDvd" onclick="startMetadataRefresh('Dvd')"
                                                class="w-full sm:w-auto bg-black/5 dark:bg-white/5 hover:bg-purple-600 hover:text-white px-8 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 border border-black/10 dark:border-white/10 shadow-sm">
                                                <i class="fa-solid fa-play" id="iconRefreshDvd"></i>
                                                <span id="textRefreshDvd">
                                                    Start opdatering
                                                </span>
                                            </button>
                                        </div>
                                    </div>
                                    <div id="progressContainerDvd"
                                        class="hidden mt-6 space-y-3 p-4 bg-black/5 dark:bg-white/5 rounded-2xl animate-in fade-in slide-in-from-top-2 duration-500">
                                        <div
                                            class="flex justify-between items-center text-[10px] uppercase font-bold tracking-widest opacity-60">
                                            <span id="progressTitleDvd">
                                                Initialiserer...
                                            </span>
                                            <span id="progressPercentDvd">0%</span>
                                        </div>
                                        <div
                                            class="w-full bg-black/10 dark:bg-white/10 rounded-full h-2 overflow-hidden">
                                            <div id="progressBarDvd"
                                                class="bg-purple-500 h-full transition-all duration-300 w-0"></div>
                                        </div>
                                        <p id="progressItemDvd" class="text-[10px] opacity-40 font-mono truncate"></p>
                                    </div>
                                </div>
                                <% } %>

                            <% if (settings.modules.games) { %>
                                <!-- Games Refresh Block -->
                                <div class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors mb-6">
                                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                                        <div class="max-w-xl">
                                            <h2 class="text-lg font-bold flex items-center gap-2 mb-2">
                                                <i class="fa-solid fa-gamepad text-emerald-600"></i>
                                                Opdater al metadata (videospil)
                                            </h2>
                                            <p class="text-xs opacity-60 leading-relaxed mb-4">
                                                Genstart dataindhentning (IGDB) for videospil.
                                            </p>
                                            <div class="flex flex-col gap-2 max-w-xs">
                                                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1">
                                                    Opdateringstilstand
                                                </label>
                                                <select id="refreshModeGame"
                                                    class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                                    <option class="bg-white dark:bg-[#1a1a1a]" value="all">

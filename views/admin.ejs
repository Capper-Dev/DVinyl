<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 md:px-6 pb-20">

    <%# Header %>
    <header class="pt-8 md:pt-14 pb-7">
        <p class="text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-sub mb-2.5">Indstillinger</p>
        <div class="flex items-end justify-between gap-4 flex-wrap">
            <h1 class="text-[32px] md:text-[56px] font-black leading-[0.95] tracking-tight">Admin</h1>
            <a href="<%= baseUrl %>/admin/personnalisation"
               class="inline-flex items-center gap-2 text-[13px] font-bold text-sub hover:text-[var(--text-main)] transition">
                Personliggør <i class="fa-solid fa-arrow-right text-[10px]"></i>
            </a>
        </div>
    </header>

    <% if (locals.successMessage) { %>
    <div class="mb-6 p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 text-sm flex items-center gap-2">
        <i class="fa-solid fa-circle-check text-xs"></i>
        <%= successMessage %>
    </div>
    <% } %>

    <%# Modules section %>
    <section class="mb-10">
        <h2 class="text-[13px] font-bold uppercase tracking-[0.18em] text-sub mb-4 flex items-center gap-2">
            <i class="fa-solid fa-cubes-stacked text-[12px]"></i>
            Moduler
        </h2>

        <form action="<%= baseUrl %>/admin/modules/save" method="POST"
              class="surface-card border border-[var(--border-color)] rounded-3xl p-6">
            <p class="text-sub text-sm mb-5">Aktivér eller deaktivér de moduler du bruger.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <% const mods = [
                    { key: 'dvd',   label: "Film & TV",  icon: 'fa-film',    needsKey: hasTmdbKey, errorId: 'error-dvd',   missing: 'TMDB API-nøgle mangler' },
                    { key: 'games', label: 'Spil',       icon: 'fa-gamepad', needsKey: hasIgdbKey, errorId: 'error-games', missing: 'IGDB/Twitch nøgler mangler' }
                ]; %>
                <% mods.forEach(mod => { %>
                <div>
                    <label class="flex items-center justify-between p-4 rounded-2xl bg-black/5 dark:bg-white/5 border border-transparent hover:border-[var(--border-color)] has-[:checked]:bg-[var(--text-main)]/5 has-[:checked]:border-[var(--text-main)]/15 transition-all cursor-pointer">
                        <div class="flex items-center gap-3">
                            <span class="w-10 h-10 rounded-xl flex items-center justify-center bg-[var(--bg-card)]">
                                <i class="fa-solid <%= mod.icon %> text-sm"></i>
                            </span>
                            <span class="text-sm font-bold"><%= mod.label %></span>
                        </div>
                        <input type="checkbox" name="<%= mod.key %>Active"
                               <%= settings.modules && settings.modules[mod.key] ? 'checked' : '' %>
                               class="sr-only peer">
                        <div class="w-11 h-6 bg-black/10 dark:bg-white/10 rounded-full peer peer-checked:bg-[var(--text-main)] relative transition-colors after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
                    </label>
                    <% if (!mod.needsKey) { %>
                    <p id="<%= mod.errorId %>" class="hidden mt-1.5 ml-1 text-[11px] text-amber-400 font-semibold">
                        <i class="fa-solid fa-triangle-exclamation text-[10px] mr-1"></i><%= mod.missing %>
                    </p>
                    <% } %>
                </div>
                <% }) %>
            </div>

            <div class="mt-5 flex justify-end">
                <button type="submit"
                        class="bg-[var(--text-main)] text-[var(--bg-page)] text-[13px] font-bold px-5 py-2.5 rounded-full hover:opacity-90 active:scale-95 transition">
                    Gem
                </button>
            </div>
        </form>
    </section>

    <%# Maintenance — metadata refresh %>
    <section class="mb-10">
        <h2 class="text-[13px] font-bold uppercase tracking-[0.18em] text-sub mb-4 flex items-center gap-2">
            <i class="fa-solid fa-arrows-rotate text-[12px]"></i>
            Vedligeholdelse
        </h2>

        <div class="grid gap-3">
            <% if (settings.modules.dvd) { %>
            <div class="surface-card border border-[var(--border-color)] rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
                <div class="min-w-0">
                    <p class="font-bold text-sm">Opdater filmmetadata</p>
                    <p class="text-sub text-xs mt-0.5">Henter genrer fra TMDB for alle film.</p>
                </div>
                <div class="flex gap-2 items-center shrink-0">
                    <select id="refreshModeDvd"
                            class="appearance-none h-9 px-3 pr-7 text-[12px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent outline-none cursor-pointer">
                        <option value="missing">Kun manglende</option>
                        <option value="all">Alle (langsommere)</option>
                    </select>
                    <button id="btnRefreshDvd" onclick="startMetadataRefresh('Dvd')"
                            class="bg-[var(--text-main)] text-[var(--bg-page)] text-[12px] font-bold px-4 h-9 rounded-full hover:opacity-90 transition flex items-center gap-2">
                        <i class="fa-solid fa-play text-[10px]" id="iconRefreshDvd"></i>
                        <span id="textRefreshDvd">Start</span>
                    </button>
                </div>
                <div id="progressContainerDvd" class="hidden w-full">
                    <div class="flex justify-between text-[10px] text-sub uppercase font-bold tracking-wider mb-1.5">
                        <span id="progressTitleDvd">Initialiserer…</span>
                        <span id="progressPercentDvd">0%</span>
                    </div>
                    <div class="w-full bg-black/10 dark:bg-white/10 rounded-full h-1 overflow-hidden">
                        <div id="progressBarDvd" class="bg-[var(--text-main)] h-full w-0 transition-all"></div>
                    </div>
                    <p id="progressItemDvd" class="text-[10px] text-sub mt-1.5 truncate"></p>
                </div>
            </div>
            <% } %>

            <% if (settings.modules.games) { %>
            <div class="surface-card border border-[var(--border-color)] rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
                <div class="min-w-0">
                    <p class="font-bold text-sm">Opdater spilmetadata</p>
                    <p class="text-sub text-xs mt-0.5">Henter genrer og covers fra IGDB.</p>
                </div>
                <div class="flex gap-2 items-center shrink-0">
                    <select id="refreshModeGame"
                            class="appearance-none h-9 px-3 pr-7 text-[12px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent outline-none cursor-pointer">
                        <option value="missing">Kun manglende</option>
                        <option value="all">Alle</option>
                    </select>
                    <button id="btnRefreshGame" onclick="startMetadataRefresh('Game')"
                            class="bg-[var(--text-main)] text-[var(--bg-page)] text-[12px] font-bold px-4 h-9 rounded-full hover:opacity-90 transition flex items-center gap-2">
                        <i class="fa-solid fa-play text-[10px]" id="iconRefreshGame"></i>
                        <span id="textRefreshGame">Start</span>
                    </button>
                </div>
                <div id="progressContainerGame" class="hidden w-full">
                    <div class="flex justify-between text-[10px] text-sub uppercase font-bold tracking-wider mb-1.5">
                        <span id="progressTitleGame">Initialiserer…</span>
                        <span id="progressPercentGame">0%</span>
                    </div>
                    <div class="w-full bg-black/10 dark:bg-white/10 rounded-full h-1 overflow-hidden">
                        <div id="progressBarGame" class="bg-[var(--text-main)] h-full w-0 transition-all"></div>
                    </div>
                    <p id="progressItemGame" class="text-[10px] text-sub mt-1.5 truncate"></p>
                </div>
            </div>
            <% } %>
        </div>
    </section>

    <%# Danger — delete last N %>
    <section class="mb-10">
        <h2 class="text-[13px] font-bold uppercase tracking-[0.18em] text-sub mb-4 flex items-center gap-2">
            <i class="fa-solid fa-clock-rotate-left text-[12px]"></i>
            Slet seneste
        </h2>
        <div class="surface-card border border-red-500/15 rounded-3xl p-5">
            <p class="text-sub text-xs mb-4">Nyttigt efter en mislykket import.</p>
            <div class="flex gap-2 items-stretch flex-wrap">
                <select id="deleteKind"
                        class="appearance-none h-11 px-4 pr-8 text-[13px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent outline-none cursor-pointer flex-1 min-w-[110px]">
                    <% if (settings.modules.dvd) { %><option value="Dvd">Film & TV</option><% } %>
                    <% if (settings.modules.games) { %><option value="Game">Spil</option><% } %>
                </select>
                <input type="number" id="deleteCount" min="1" placeholder="Antal"
                       class="h-11 px-4 text-[13px] font-semibold rounded-full bg-black/5 dark:bg-white/5 border border-transparent outline-none focus:border-red-500/40 transition w-24">
                <button onclick="confirmDeleteLast()"
                        class="bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/20 hover:border-red-500 font-bold h-11 px-5 rounded-full transition flex items-center gap-2 text-[13px]">
                    <i class="fa-solid fa-trash text-[11px]"></i>
                    Slet
                </button>
            </div>
            <p id="deleteResult" class="hidden mt-3 text-[12px]"></p>
        </div>
    </section>

    <%# Backup %>
    <section class="mb-10">
        <h2 class="text-[13px] font-bold uppercase tracking-[0.18em] text-sub mb-4 flex items-center gap-2">
            <i class="fa-solid fa-database text-[12px]"></i>
            Backup
        </h2>
        <div class="surface-card border border-[var(--border-color)] rounded-3xl p-5 flex items-center justify-between gap-3 flex-wrap">
            <p class="text-sm">Eksportér eller importér hele samlingen som JSON.</p>
            <div class="flex gap-2">
                <a href="<%= baseUrl %>/backup/export"
                   class="inline-flex items-center gap-2 bg-black/5 dark:bg-white/5 text-[13px] font-bold px-4 h-10 rounded-full hover:bg-black/10 dark:hover:bg-white/10 transition">
                    <i class="fa-solid fa-file-export text-[11px]"></i>
                    Eksportér
                </a>
                <label class="inline-flex items-center gap-2 bg-black/5 dark:bg-white/5 text-[13px] font-bold px-4 h-10 rounded-full hover:bg-amber-500 hover:text-white transition cursor-pointer">
                    <i class="fa-solid fa-file-import text-[11px]"></i>
                    Importér
                    <input type="file" id="backupInput" class="hidden" accept=".json">
                </label>
            </div>
        </div>
    </section>

    <%# Sign out %>
    <section>
        <form action="<%= baseUrl %>/logout" method="POST" class="flex justify-end">
            <button type="submit"
                    class="inline-flex items-center gap-2 text-[13px] font-bold text-sub hover:text-red-500 transition">
                <i class="fa-solid fa-arrow-right-from-bracket text-[11px]"></i>
                Log ud
            </button>
        </form>
    </section>
</div>

<script src="<%= baseUrl %>/socket.io/socket.io.js"></script>
<script>
    const socket = io({ path: '<%= baseUrl %>/socket.io' });
    let activeRefreshKind = null;

    async function confirmDeleteLast() {
        const kind  = document.getElementById('deleteKind').value;
        const count = parseInt(document.getElementById('deleteCount').value);
        const result = document.getElementById('deleteResult');
        if (!count || count < 1) {
            result.className = 'mt-3 text-[12px] text-red-400';
            result.textContent = 'Indtast et antal.';
            result.classList.remove('hidden');
            return;
        }
        if (!confirm(`Slet de ${count} seneste ${kind === 'Dvd' ? 'film' : 'spil'}?`)) return;
        try {
            const res = await fetch('<%= baseUrl %>/admin/delete-last-items', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ count, kind })
            });
            const data = await res.json();
            result.className = res.ok ? 'mt-3 text-[12px] text-emerald-400' : 'mt-3 text-[12px] text-red-400';
            result.textContent = res.ok ? `${data.deleted} elementer slettet.` : (data.error || 'Fejl.');
            result.classList.remove('hidden');
        } catch (e) {
            result.className = 'mt-3 text-[12px] text-red-400';
            result.textContent = 'Netværksfejl.';
            result.classList.remove('hidden');
        }
    }

    async function startMetadataRefresh(kind) {
        if (!confirm('Start metadataopdatering?')) return;
        activeRefreshKind = kind;
        const mode = document.getElementById('refreshMode' + kind).value;
        const btn = document.getElementById('btnRefresh' + kind);
        const icon = document.getElementById('iconRefresh' + kind);
        const text = document.getElementById('textRefresh' + kind);
        const wrap = document.getElementById('progressContainer' + kind);
        btn.disabled = true;
        btn.classList.add('opacity-60', 'cursor-not-allowed');
        icon.className = 'fa-solid fa-spinner fa-spin text-[10px]';
        text.textContent = 'Starter';
        wrap.classList.remove('hidden');
        try {
            const url = kind === 'Game' ? '<%= baseUrl %>/admin/refresh-all-games-metadata' : '<%= baseUrl %>/admin/refresh-all-dvds-metadata';
            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mode })
            });
            if (!res.ok) {
                const data = await res.json();
                throw new Error(data.error || 'Fejl');
            }
        } catch (err) {
            alert(err.message);
            resetRefreshBtn(kind);
        }
    }

    function resetRefreshBtn(kind) {
        const btn = document.getElementById('btnRefresh' + kind);
        const icon = document.getElementById('iconRefresh' + kind);
        const text = document.getElementById('textRefresh' + kind);
        const wrap = document.getElementById('progressContainer' + kind);
        if (btn) { btn.disabled = false; btn.classList.remove('opacity-60', 'cursor-not-allowed'); }
        if (icon) icon.className = 'fa-solid fa-play text-[10px]';
        if (text) text.textContent = 'Start';
        if (wrap) wrap.classList.add('hidden');
        activeRefreshKind = null;
    }

    socket.on('refresh_all_progress', d => {
        if (!activeRefreshKind) return;
        const k = activeRefreshKind;
        const pct = Math.round((d.current / d.total) * 100);
        document.getElementById('progressBar' + k).style.width = pct + '%';
        document.getElementById('progressPercent' + k).textContent = pct + '%';
        document.getElementById('progressTitle' + k).textContent = `${d.current} / ${d.total}`;
        document.getElementById('progressItem' + k).textContent = d.title;
    });
    socket.on('refresh_all_finished', d => {
        if (!activeRefreshKind) return;
        alert(`Færdig: ${d.count} opdateret.`);
        resetRefreshBtn(activeRefreshKind);
    });

    // Backup import
    const backupInput = document.getElementById('backupInput');
    if (backupInput) {
        backupInput.onchange = function () {
            const file = this.files[0];
            if (!file) return;
            if (!confirm('Importér denne backup? Det erstatter ALT eksisterende data.')) { this.value = ''; return; }
            const reader = new FileReader();
            reader.onload = async (e) => {
                try {
                    const data = JSON.parse(e.target.result);
                    const res = await fetch('<%= baseUrl %>/backup/import', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ backupData: data })
                    });
                    if (res.ok) {
                        alert('Import gennemført. Genindlæser…');
                        window.location.reload();
                    } else {
                        const err = await res.json();
                        alert('Fejl: ' + (err.error || 'ukendt'));
                    }
                } catch (err) {
                    alert('Ugyldig JSON-fil.');
                }
            };
            reader.readAsText(file);
            this.value = '';
        };
    }
</script>

<%- include('partials/footer') %>

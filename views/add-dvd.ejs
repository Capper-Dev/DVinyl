<%- include('partials/header') %>

<div class="max-w-screen-lg mx-auto pb-20 px-4">
    
    <div class="text-center mb-8 md:mb-12 pt-4 md:pt-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-theme/10 text-primary-theme mb-4">
            <i class="fa-solid fa-film text-3xl"></i>
        </div>
        <h1 class="text-3xl md:text-4xl font-black"><%= t('add_dvd.title') %></h1>
        <p class="opacity-60 mt-2"><%= t('add_dvd.desc') %></p>
    </div>

    <form action="<%= baseUrl %>/search-dvds" method="POST" class="max-w-2xl mx-auto mb-10">
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-grow relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none z-10">
                    <i class="fa-solid fa-search opacity-50 group-focus-within:text-primary-theme transition-colors"></i>
                </div>
                <input type="text" name="query" value="<%= locals.scanned_barcode || '' %>"
                    class="block w-full p-4 pl-12 text-base bg-black/5 dark:bg-white/5 border border-transparent focus:border-primary-theme rounded-2xl focus:ring-2 focus:ring-primary-theme/50 placeholder-opacity-50 transition-all outline-none"
                    placeholder="<%= t('add_dvd.search_placeholder') || 'Titre, Réalisateur ou Code-barres...' %>" autofocus required>
            </div>
            <button type="submit"
                class="bg-primary-theme hover:brightness-110 text-white font-bold px-8 py-4 rounded-2xl shadow-lg shadow-primary-theme/20 transition-all active:scale-95 flex items-center justify-center gap-2 whitespace-nowrap">
                <i class="fa-solid fa-search"></i>
                <%= t('common.search') %>
            </button>
        </div>

        <div class="flex items-center gap-3 mt-4 justify-center">
            <span class="text-xs font-bold uppercase opacity-30"><%= t('add_dvd.separator_or') %></span>
        </div>

        <div class="flex justify-center mt-3">
            <button type="button" id="start-scan"
                class="bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center gap-2 active:scale-95">
                <i class="fa-solid fa-barcode"></i>
                <%= t('add_dvd.btn_scan') %>
            </button>
        </div>

        <div class="hidden mt-6" id="readerWrapper">
            <div class="relative rounded-2xl overflow-hidden shadow-lg border border-black/10 dark:border-white/10 bg-black" style="aspect-ratio:4/3">
                <video id="scanVideo" class="w-full h-full object-cover" autoplay playsinline muted></video>
                <div class="absolute inset-0 pointer-events-none flex items-center justify-center">
                    <div class="w-64 h-24 relative">
                        <div class="absolute inset-0 border-2 border-primary-theme/50 rounded-lg"></div>
                        <span class="absolute -top-px -left-px w-5 h-5 border-t-2 border-l-2 border-primary-theme rounded-tl"></span>
                        <span class="absolute -top-px -right-px w-5 h-5 border-t-2 border-r-2 border-primary-theme rounded-tr"></span>
                        <span class="absolute -bottom-px -left-px w-5 h-5 border-b-2 border-l-2 border-primary-theme rounded-bl"></span>
                        <span class="absolute -bottom-px -right-px w-5 h-5 border-b-2 border-r-2 border-primary-theme rounded-br"></span>
                        <div id="scanLine" class="absolute left-0 right-0 h-0.5 bg-primary-theme shadow-lg shadow-primary-theme/60" style="animation: scanMove 1.8s ease-in-out infinite;"></div>
                    </div>
                </div>
                <button type="button" id="stop-scan" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-black/80 transition">
                    <i class="fa-solid fa-xmark text-sm"></i>
                </button>
            </div>
            <p class="text-center text-xs opacity-40 mt-2">Point camera at barcode</p>
        </div>
        <style>
            @keyframes scanMove {
                0%, 100% { top: 10%; opacity: 0.5; }
                50% { top: 85%; opacity: 1; }
            }
        </style>
    </form>

    <% if (locals.results) { %>
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-xl font-bold transition-colors"><%= t('add_dvd.results_title') %></h2>
            <span class="bg-black/10 dark:bg-white/10 text-xs font-mono px-2 py-1 rounded opacity-70 transition-colors"><%= results.length %></span>
        </div>

        <% if (results.length === 0) { %>
            <div class="text-center py-12 card-theme bg-opacity-50 rounded-xl border-dashed opacity-70 transition-colors">
                <i class="fa-solid fa-ghost text-4xl mb-3 opacity-50"></i>
                <p><%= t('add_dvd.no_results') %></p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <% results.forEach(item => { %>
                    <a href="<%= baseUrl %>/confirm-dvd/<%= item.media_type %>/<%= item.tmdb_id %><%= locals.scanned_barcode ? '?barcode=' + locals.scanned_barcode : '' %>" class="card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all group flex flex-col hover:shadow-lg hover:-translate-y-1">
                        <div class="relative aspect-[2/3] bg-black/5 dark:bg-white/5">
                            <% if(item.cover_image && !item.cover_image.includes('spacer.gif')) { %>
                                <img src="<%= item.cover_image %>" onerror="this.onerror=null; this.src='<%= baseUrl %>/ressources/no-pp.jpg';" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center opacity-30">
                                    <i class="fa-solid fa-film text-3xl"></i>
                                </div>
                            <% } %>
                            
                           <div class="absolute top-2 right-2 bg-black/70 text-white text-[9px] font-bold px-1.5 py-0.5 rounded backdrop-blur-sm uppercase">
                                <%= item.media_type === 'tv' 
                                    ? t('add_dvd.tv_show') 
                                    : t('add_dvd.movie') %>
                            </div>
                        </div>

                        <div class="p-3 flex flex-col flex-grow">
                            <h3 class="font-bold text-sm leading-tight mb-1 line-clamp-2 transition-colors"><%= item.title %></h3>
                            <p class="opacity-40 text-[10px] mb-2 transition-colors"><%= item.year %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    const scanButton = document.getElementById('start-scan');
    const stopButton = document.getElementById('stop-scan');
    const readerWrapper = document.getElementById('readerWrapper');
    const video = document.getElementById('scanVideo');
    const searchInput = document.querySelector('input[name="query"]');
    const form = document.querySelector('form[action="<%= baseUrl %>/search-dvds"]');
    let stream = null;
    let scanInterval = null;
    const BARCODE_FORMATS = ['ean_13', 'ean_8', 'upc_a', 'upc_e'];

    async function startScanner() {
        readerWrapper.classList.remove('hidden');
        scanButton.disabled = true;
        scanButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> <span>Starting...</span>';

        try {
            stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: { ideal: 'environment' }, width: { ideal: 1280 }, height: { ideal: 720 } }
            });
            video.srcObject = stream;
            await video.play();

            const track = stream.getVideoTracks()[0];
            if (track.applyConstraints) {
                track.applyConstraints({ advanced: [{ focusMode: 'continuous' }] }).catch(() => {});
            }

            scanButton.innerHTML = '<i class="fa-solid fa-barcode"></i> <span>Scanning...</span>';

            if (window.BarcodeDetector) {
                const detector = new BarcodeDetector({ formats: BARCODE_FORMATS });
                scanInterval = setInterval(async () => {
                    try {
                        const codes = await detector.detect(video);
                        if (codes.length > 0) onBarcodeFound(codes[0].rawValue);
                    } catch (e) {}
                }, 200);
            } else {
                stopScanner();
                alert('Barcode scanning not supported in this browser. Please type the barcode manually.');
            }
        } catch (err) {
            stopScanner();
            alert('Camera error: ' + err.message);
        }
    }

    function stopScanner() {
        clearInterval(scanInterval);
        scanInterval = null;
        if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        video.srcObject = null;
        readerWrapper.classList.add('hidden');
        scanButton.disabled = false;
        scanButton.innerHTML = '<i class="fa-solid fa-barcode"></i> <span><%= t("add_dvd.btn_scan") %></span>';
    }

    function onBarcodeFound(code) {
        stopScanner();
        searchInput.value = code;
        form.submit();
    }

    scanButton.addEventListener('click', startScanner);
    stopButton.addEventListener('click', stopScanner);
</script>

<%- include('partials/footer') %>

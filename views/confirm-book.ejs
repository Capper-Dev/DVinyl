<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="<%= baseUrl %>/add-book" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> <%= t('common.back_to_search') %>
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                
                <div class="aspect-[2/3] rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= book.cover_image %>" class="w-full h-full object-cover transition-all duration-500">
                    <div class="absolute inset-0 bg-black/40 hidden group-hover:flex items-center justify-center text-white text-xs font-bold backdrop-blur-sm">
                        <%= t('confirm_book.cover_preview') %>
                    </div>
                </div>
                
                <h2 class="text-xl font-bold mb-1 leading-tight"><%= book.title %></h2>
                <p class="opacity-60 mb-4"><%= book.author %></p>

                <div class="space-y-3 text-sm border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_book.publisher_label')%></span>
                        <span class="font-medium text-right"><%= book.publisher || '-' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_book.isbn_label') || 'ISBN' %></span>
                        <span class="font-mono opacity-80"><%= book.isbn || '-' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_book.year_label') %></span>
                        <span><%= book.year || '-' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_book.pages_label')  %></span>
                        <span><%= book.pages ? book.pages + ' p.' : '-' %></span>
                    </div>
                </div>

                <% if(book.description) { %>
                    <div class="mt-6 border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                        <h3 class="text-xs uppercase font-bold opacity-50 mb-3"><%= t('confirm_book.description_title') %></h3>
                        <div class="text-sm opacity-70 max-h-40 overflow-y-auto pr-2 custom-scrollbar text-justify">
                            <%= book.description %>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> <%= t('confirm_book.config_title') %>
                </h1>

                <form action="<%= baseUrl %>/save-book" method="POST" class="space-y-6">
                    <input type="hidden" name="hardcover_id" value="<%= book.hardcover_id %>">
                    <input type="hidden" name="hardcover_slug" value="<%= book.hardcover_slug %>">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_title') %></label>
                            <input type="text" name="title" value="<%= book.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_author') %></label>
                            <input type="text" name="author" value="<%= book.author %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_publisher') %></label>
                            <input type="text" name="publisher" value="<%= book.publisher %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_year') %></label>
                            <input type="text" name="year" value="<%= book.year %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60 flex items-center gap-2">
                                <%= t('confirm_book.field_isbn') || 'ISBN' %>
                                <label class="cursor-pointer flex items-center ml-auto" title="<%= t('confirm_vinyl.barcode_locked') %>">
                                    <input type="checkbox" name="barcode_locked" class="hidden peer">
                                    <i class="fa-solid fa-unlock opacity-30 peer-checked:hidden"></i>
                                    <i class="fa-solid fa-lock text-primary-theme hidden peer-checked:block"></i>
                                </label>
                            </label>
                            <input type="text" name="barcode" value="<%= book.isbn %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none font-mono" placeholder="ISBN...">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div class="md:col-span-2">
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme opacity-60">
                                <%= t('confirm_book.field_format') %>
                            </label>
                            <select name="format" 
                                    class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                
                                <option value="paperback" class="bg-white dark:bg-[#1a1a1a]" <%= book.format === 'paperback' ? 'selected' : '' %>>
                                    <%= t('format.paperback') %>
                                </option>
                                <option value="hardcover" class="bg-white dark:bg-[#1a1a1a]" <%= book.format === 'hardcover' ? 'selected' : '' %>>
                                    <%= t('format.hardcover') %>
                                </option>
                                <option value="manga" class="bg-white dark:bg-[#1a1a1a]" <%= book.format === 'manga' ? 'selected' : '' %>>
                                    <%= t('format.manga') %>
                                </option>
                                <option value="comic" class="bg-white dark:bg-[#1a1a1a]" <%= book.format === 'comic' ? 'selected' : '' %>>
                                    <%= t('format.comic') %>
                                </option>
                                <option value="graphic_novel" class="bg-white dark:bg-[#1a1a1a]" <%= book.format === 'graphic_novel' ? 'selected' : '' %>>
                                    <%= t('format.graphic_novel') %>
                                </option>
                            </select>
                        </div>
                        <div class="w-full md:w-1/2">
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">
                                <%= t('confirm_vinyl.field_quantity') %>
                            </label>
                            <input type="number" name="quantity" value="1" min="1" 
                                class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme"><%= t('confirm_book.field_pages') %></label>
                            <input type="number" name="pages" value="<%= book.pages %>" class="bg-black/5 dark:bg-white/5 border border-primary-theme/30 text-sm rounded-lg focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme"><%= t('confirm_book.field_language') %></label>
                            <input type="text" name="language" value="<%= book.language %>" class="bg-black/5 dark:bg-white/5 border border-primary-theme/30 text-sm rounded-lg focus:ring-primary-theme block w-full p-3 transition-colors outline-none" placeholder="Ex: fr, en">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-black/5 dark:bg-white/5 p-4 rounded-lg border border-black/10 dark:border-white/10">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_series') %></label>
                            <input type="text" name="series" class="bg-white dark:bg-black/20 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none" placeholder="Ex: Harry Potter, One Piece...">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_volume') %></label>
                            <input type="number" name="volume" class="bg-white dark:bg-black/20 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none" placeholder="Numéro">
                        </div>
                    </div>

                    <input type="hidden" name="cover_image" value="<%= book.cover_image %>">
                    <input type="hidden" name="readingStatus" value="to_read">
                    <input type="hidden" name="rating" value="0">

                    <div class="mb-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-layer-group mr-1"></i> <%= t('common.collection') || 'Collection' %>
                            </label>
                            <select name="collection_id" class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all cursor-pointer">
                                <option value="">Uncategorized</option>
                                <% if (typeof collections !== 'undefined') { %>
                                <% collections.forEach(function(col) { %>
                                <option value="<%= col._id %>"><%= col.name %></option>
                                <% }) %>
                                <% } %>
                            </select>
                        </div>

                    <div class="pt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <button type="submit" name="in_wishlist" value="true" class="bg-black/5 dark:bg-white/5 hover:bg-pink-500 hover:text-white font-bold rounded-lg text-sm px-5 py-4 transition-colors flex items-center justify-center gap-2">
                            <i class="fa-solid fa-gift"></i> <%= t('confirm_vinyl.btn_wishlist') %>
                        </button>
                        <button type="submit" name="in_wishlist" value="false" class="text-white bg-primary-theme hover:brightness-110 font-bold rounded-lg text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                            <i class="fa-solid fa-check"></i> <%= t('confirm_book.btn_collection') %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="<%= baseUrl %>/add-dvd" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> Tilbage til søgning
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                
                <div class="aspect-[2/3] rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= dvd.cover_image %>" class="w-full h-full object-cover transition-all duration-500">
                    <div class="absolute inset-0 bg-black/40 hidden group-hover:flex items-center justify-center text-white text-xs font-bold backdrop-blur-sm cursor-pointer" onclick="document.getElementById('checkEditCover').click()">
                        Erstat hovedcover
                    </div>
                    <div class="absolute top-2 right-2 bg-black/70 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-sm uppercase">
                        <%= dvd.media_type === 'tv' ? 'Serie' : 'Film' %>
                    </div>
                </div>
                
                <h2 class="text-xl font-bold mb-1 leading-tight"><%= dvd.title %></h2>
                <p class="opacity-60 mb-4"><%= dvd.director %></p>

                <div class="space-y-3 text-sm border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                    <div class="flex justify-between">
                        <span class="opacity-60">Studie</span>
                        <span class="font-medium text-right truncate ml-4"><%= dvd.studio || '-' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60">År</span>
                        <span><%= dvd.year || '-' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60">Varighed</span>
                        <span class="font-mono opacity-80"><%= dvd.duration || '-' %></span>
                    </div>
                </div>

                <% if(dvd.description) { %>
                    <div class="mt-6 border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                        <h3 class="text-xs uppercase font-bold opacity-50 mb-3">Resumé</h3>
                        <div class="text-sm opacity-70 max-h-40 overflow-y-auto pr-2 custom-scrollbar text-justify">
                            <%= dvd.description %>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> Bekræft og udfyld
                </h1>

                <form action="<%= baseUrl %>/save-dvd" method="POST" class="space-y-6">
                    <input type="hidden" name="tmdb_id" value="<%= dvd.tmdb_id %>">
                    <input type="hidden" name="media_type" value="<%= dvd.media_type %>">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Titel</label>
                            <input type="text" name="title" value="<%= dvd.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Instruktør</label>
                            <input type="text" name="director" value="<%= dvd.director %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Studie</label>
                            <input type="text" name="studio" value="<%= dvd.studio %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">År</label>
                                <input type="text" name="year" value="<%= dvd.year %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                            </div>
                            <div>
                                <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Varighed</label>
                                <input type="text" name="duration" value="<%= dvd.duration %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme opacity-60">
                                Format
                            </label>
                            <select name="format" class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                <option value="dvd" class="bg-white dark:bg-[#1a1a1a]">DVD</option>
                                <option value="bluray" class="bg-white dark:bg-[#1a1a1a]">Blu-ray</option>
                                <option value="4k" class="bg-white dark:bg-[#1a1a1a]">4K UHD</option>
                                <option value="vhs" class="bg-white dark:bg-[#1a1a1a]">VHS</option>
                            </select>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60 flex items-center gap-2">
                                Stregkode
                                <label class="cursor-pointer flex items-center ml-auto" title="Lås stregkode">
                                    <input type="checkbox" name="barcode_locked" class="hidden peer">
                                    <i class="fa-solid fa-unlock opacity-30 peer-checked:hidden"></i>
                                    <i class="fa-solid fa-lock text-primary-theme hidden peer-checked:block"></i>
                                </label>
                            </label>
                            <input type="text" name="barcode" value="<%= scanned_barcode || '' %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none font-mono" placeholder="Code-barres...">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Antal</label>
                            <input type="number" name="quantity" value="1" min="1" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>
                    
                    <div class="flex items-center">
                        <input id="is_boxset" type="checkbox" name="is_boxset" value="true" class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                        <label for="is_boxset" class="ml-2 text-sm font-bold cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
                            Det er et boksæt (Boxset)
                        </label>
                    </div>

                    <input type="hidden" name="cover_image" value="<%= dvd.cover_image %>">
                    <input type="hidden" name="watchStatus" value="to_watch">
                    <input type="hidden" name="user_rating" value="0">

                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider opacity-60 mb-2">Collection</label>
                        <select name="collection_id" class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-theme transition-all">
                            <option value="">Uncategorized</option>
                            <% if (typeof collections !== 'undefined') { %>
                            <% collections.forEach(function(col) { %>
                            <option value="<%= col._id %>"><%= col.name %></option>
                            <% }) %>
                            <% } %>
                        </select>
                    </div>

                    <div class="pt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <button type="submit" name="in_wishlist" value="true" class="bg-black/5 dark:bg-white/5 hover:bg-pink-500 hover:text-white font-bold rounded-lg text-sm px-5 py-4 transition-colors flex items-center justify-center gap-2">
                            <i class="fa-solid fa-gift"></i> Ønskeliste
                        </button>
                        <button type="submit" name="in_wishlist" value="false" class="text-white bg-primary-theme hover:brightness-110 font-bold rounded-lg text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                            <i class="fa-solid fa-check"></i> Tilføj til samlingen
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 md:px-6 pb-20">

    <header class="pt-8 md:pt-14 pb-7">
        <p class="text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-sub mb-2.5">Min konto</p>
        <h1 class="text-[32px] md:text-[56px] font-black leading-[0.95] tracking-tight">Indstillinger</h1>
    </header>

    <section class="mb-8">
        <div class="surface-card border border-[var(--border-color)] rounded-3xl p-6">
            <p class="text-[10px] font-bold uppercase tracking-widest text-sub mb-2">Logget ind som</p>
            <p class="text-2xl font-black capitalize"><%= user?.name || '—' %></p>
        </div>
    </section>

    <section class="mb-8">
        <div class="surface-card border border-[var(--border-color)] rounded-3xl p-6">
            <p class="text-[10px] font-bold uppercase tracking-widest text-sub mb-3">Tema</p>
            <p class="text-sm text-sub mb-4">Gemmes lokalt på denne enhed.</p>
            <button type="button" id="settings-theme-toggle"
                    class="inline-flex items-center gap-2 bg-black/5 dark:bg-white/5 text-[13px] font-bold px-4 h-10 rounded-full hover:bg-black/10 dark:hover:bg-white/10 transition">
                <i id="settings-theme-icon" class="fa-solid fa-moon text-[12px]"></i>
                <span id="settings-theme-label">Skift tema</span>
            </button>
        </div>
    </section>

    <section>
        <form action="<%= baseUrl %>/logout" method="POST">
            <button type="submit"
                    class="w-full inline-flex items-center justify-center gap-2 text-[13px] font-bold text-red-500 bg-red-500/10 hover:bg-red-500 hover:text-white border border-red-500/20 hover:border-red-500 h-12 rounded-full transition">
                <i class="fa-solid fa-arrow-right-from-bracket text-[11px]"></i>
                Log ud
            </button>
        </form>
    </section>
</div>

<script>
    const stBtn = document.getElementById('settings-theme-toggle');
    const stIcon = document.getElementById('settings-theme-icon');
    const stLabel = document.getElementById('settings-theme-label');
    const html = document.documentElement;

    function syncSettingsTheme() {
        const dark = html.classList.contains('dark');
        if (stIcon) stIcon.className = dark ? 'fa-solid fa-sun text-[12px]' : 'fa-solid fa-moon text-[12px]';
        if (stLabel) stLabel.textContent = dark ? 'Skift til lyst' : 'Skift til mørkt';
    }
    syncSettingsTheme();
    stBtn?.addEventListener('click', () => {
        html.classList.toggle('dark');
        try { localStorage.setItem('dvinyl-theme', html.classList.contains('dark') ? 'dark' : 'light'); } catch (e) {}
        syncSettingsTheme();
    });
</script>

<%- include('partials/footer') %>

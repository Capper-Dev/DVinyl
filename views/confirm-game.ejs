<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="<%= baseUrl %>/add-game" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> Tilbage til søgning
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                
                <div class="aspect-[3/4] rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= game.cover_image %>" class="w-full h-full object-contain transition-all duration-500 p-2">
                    <div class="absolute inset-0 bg-black/40 hidden group-hover:flex items-center justify-center text-white text-xs font-bold backdrop-blur-sm cursor-pointer" onclick="document.getElementById('checkEditCover').click()">
                        Erstat cover
                    </div>
                    <div class="absolute top-2 right-2 bg-primary-theme/90 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-sm uppercase">
                        <i class="fa-solid fa-gamepad mr-1"></i> Spil
                    </div>
                </div>
                
                <h2 class="text-xl font-bold mb-1 leading-tight"><%= game.title %></h2>
                <p class="opacity-60 mb-4"><%= game.developer || game.publisher || '' %></p>

                <div class="space-y-3 text-sm border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                    <% if (game.developer) { %>
                    <div class="flex justify-between">
                        <span class="opacity-60">Udvikler</span>
                        <span class="font-medium text-right truncate ml-4"><%= game.developer %></span>
                    </div>
                    <% } %>
                    <% if (game.publisher) { %>
                    <div class="flex justify-between">
                        <span class="opacity-60">Udgiver</span>
                        <span class="font-medium text-right truncate ml-4"><%= game.publisher %></span>
                    </div>
                    <% } %>
                    <div class="flex justify-between">
                        <span class="opacity-60">År</span>
                        <span><%= game.year || '-' %></span>
                    </div>
                    <% if (game.platforms_text) { %>
                    <div class="flex justify-between">
                        <span class="opacity-60">Platform</span>
                        <span class="text-right text-xs truncate ml-4"><%= game.platforms_text %></span>
                    </div>
                    <% } %>
                </div>

                <% if(game.summary) { %>
                    <div class="mt-6 border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                        <h3 class="text-xs uppercase font-bold opacity-50 mb-3">Resumé</h3>
                        <div class="text-sm opacity-70 max-h-40 overflow-y-auto pr-2 custom-scrollbar text-justify">
                            <%= game.summary %>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> Bekræft og udfyld
                </h1>

                <form action="<%= baseUrl %>/save-game" method="POST" class="space-y-6">
                    <input type="hidden" name="igdb_id" value="<%= game.igdb_id %>">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Titel</label>
                            <input type="text" name="title" value="<%= game.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Udvikler</label>
                            <input type="text" name="developer" value="<%= game.developer %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Udgiver</label>
                            <input type="text" name="publisher" value="<%= game.publisher %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">År</label>
                            <input type="text" name="year" value="<%= game.year %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme opacity-80">
                                <i class="fa-solid fa-gamepad mr-1"></i> Platform
                            </label>
                            <select name="platform" class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                <% game.platforms.forEach(p => { %>
                                    <option value="<%= p.name %>" class="bg-white dark:bg-[#1a1a1a]"><%= p.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">
                                <i class="fa-solid fa-globe mr-1"></i> Region
                            </label>
                            <input type="text" name="region" placeholder="PAL / NTSC / NTSC-J..." class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Format</label>
                            <select name="format" class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                <option value="physical" class="bg-white dark:bg-[#1a1a1a]">Fysisk</option>
                                <option value="collector" class="bg-white dark:bg-[#1a1a1a]">Samler</option>
                                <option value="limited" class="bg-white dark:bg-[#1a1a1a]">Begrænset udgave</option>
                                <option value="steelbook" class="bg-white dark:bg-[#1a1a1a]">Steelbook</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60 flex items-center gap-2">
                                Stregkode
                                <label class="cursor-pointer flex items-center ml-auto" title="Lås stregkode">
                                    <input type="checkbox" name="barcode_locked" class="hidden peer">
                                    <i class="fa-solid fa-unlock opacity-30 peer-checked:hidden"></i>
                                    <i class="fa-solid fa-lock text-primary-theme hidden peer-checked:block"></i>
                                </label>
                            </label>
                            <input type="text" name="barcode" value="<%= scanned_barcode || '' %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none font-mono" placeholder="Code-barres...">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">Antal</label>
                            <input type="number" name="quantity" value="1" min="1" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <input type="hidden" name="cover_image" value="<%= game.cover_image %>">
                    <input type="hidden" name="playStatus" value="to_play">
                    <input type="hidden" name="user_rating" value="0">

                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider opacity-60 mb-2">Collection</label>
                        <select name="collection_id" class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-theme transition-all">
                            <option value="">Uncategorized</option>
                            <% if (typeof collections !== 'undefined') { %>
                            <% collections.forEach(function(col) { %>
                            <option value="<%= col._id %>"><%= col.name %></option>
                            <% }) %>
                            <% } %>
                        </select>
                    </div>

                    <div class="pt-6">
                        <button type="submit" class="w-full text-white bg-primary-theme hover:brightness-110 font-bold rounded-lg text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                            <i class="fa-solid fa-check"></i> Tilføj til samlingen
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<%- include('partials/footer') %>

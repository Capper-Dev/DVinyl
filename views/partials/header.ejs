<!DOCTYPE html>
<% 
  const isDark = (typeof locals.isDark !== 'undefined') ? locals.isDark : true;
  const currentLng = (typeof locals.currentLng !== 'undefined') ? locals.currentLng : 'fr';
  const THEMES = (typeof locals.allThemes !== 'undefined') ? locals.allThemes : {};
  
  const rawCategory = (typeof locals.currentType !== 'undefined') ? locals.currentType : (locals.detectedType || 'home');

  let themeKey = 'home'; 
  
  const musicTypes = ['music', 'vinyl', 'cd', 'cassette', 'add-vinyl', 'album'];
  const bookTypes  = ['books', 'add-book', 'book'];
  const dvdTypes   = ['dvd', 'add-dvd'];
  const gameTypes  = ['games', 'add-game', 'game'];

  if (musicTypes.includes(rawCategory)) {
      themeKey = 'music';
  } else if (bookTypes.includes(rawCategory)) {
      themeKey = 'books';
  } else if (dvdTypes.includes(rawCategory)) {
      themeKey = 'dvd';
  } else if (gameTypes.includes(rawCategory)) {
      themeKey = 'games';
  }

  let activePresetKey = 'default';
  if (typeof settings !== 'undefined' && settings && settings.theme) {
        if (settings.theme[themeKey] && settings.theme[themeKey].preset) {
          activePresetKey = settings.theme[themeKey].preset;
      } 
      else if (settings.theme.home && settings.theme.home.preset) {
          activePresetKey = settings.theme.home.preset;
      }
  }

  const safeFallback = { 
      light: { bg: '#e2e8f0', card: '#ffffff', navbar: '#1e293b', navText: '#ffffff', text: '#0f172a', subtext: '#475569', highlight: '#10b981' },
      dark:  { bg: '#171717', card: '#262626', navbar: '#0a0a0a', navText: '#ffffff', text: '#ffffff', subtext: '#a3a3a3', highlight: '#10b981' }
  };

  const activeTheme = (THEMES[activePresetKey]) ? THEMES[activePresetKey] : (THEMES['default'] || safeFallback);
%>

<html lang="<%= currentLng %>" class="<%= isDark ? 'dark' : '' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DVinyl</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            theme: {
                bg: 'var(--bg-page)',
                card: 'var(--bg-card)',
                nav: 'var(--bg-nav)',
                text: 'var(--text-main)',
                subtext: 'var(--text-sub)',
                highlight: 'var(--highlight)'
            }
          }
        }
      }
    };
  </script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.6.5/flowbite.min.js"></script>
  <link rel="icon" type="image/png" href="<%= baseUrl %>/ressources/logo.png">

  <style>
    :root {
        --bg-page: <%= activeTheme.light.bg %>;
        --bg-card: <%= activeTheme.light.card %>;
        --bg-nav:  <%= activeTheme.light.navbar %>;
        --text-main: <%= activeTheme.light.text %>;
        --text-sub: <%= activeTheme.light.subtext %>;
        --highlight: <%= activeTheme.light.highlight %>;
        
        --shadow-color: 0 0 0 rgba(0,0,0,0.05);
        --border-color: rgba(0,0,0,0.1);
    }

    html.dark {
        --bg-page: <%= activeTheme.dark.bg %>;
        --bg-card: <%= activeTheme.dark.card %>;
        --bg-nav:  <%= activeTheme.dark.navbar %>;
        --text-main: <%= activeTheme.dark.text %>;
        --text-sub: <%= activeTheme.dark.subtext %>;
        --highlight: <%= activeTheme.dark.highlight %>;
        
        --shadow-color: 0 0 20px <%= activeTheme.dark.highlight %>20;
        --border-color: rgba(255,255,255,0.1);
    }

    body {
        background-color: var(--bg-page) !important;
        color: var(--text-main) !important;
    }

    .nav-custom {
        background-color: var(--bg-nav) !important;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-main) !important;
    }

    .text-primary-theme { color: var(--highlight) !important; }
    .bg-primary-theme { background-color: var(--highlight) !important; color: #fff; }
    
    .card-theme {
        background-color: var(--bg-card) !important;
        border: 1px solid var(--border-color);
        color: var(--text-main) !important;
    }
    
    #page-loader {
      background-color: var(--bg-page);
      color: var(--text-main);
    }
  </style>

  <link rel="manifest" href="<%= baseUrl %>/manifest.json">
  <meta name="theme-color" content="#0f0f0f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="DVinyl">
  <link rel="apple-touch-icon" href="<%= baseUrl %>/ressources/icone-192.png">
</head>

<body class="font-sans transition-colors duration-300">
    
  <div id="page-loader" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center transition-opacity duration-500">
    <div class="relative">
        <i class="fa-solid fa-compact-disc fa-spin text-4xl opacity-40 text-[var(--text-main)]"></i>
    </div>
  </div>

  <nav class="nav-custom transition-colors duration-300">
      <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
      
      <a href="<%= baseUrl || '/' %>" class="flex items-center space-x-3 group">
        <img src="<%= baseUrl %>/ressources/logo.png" alt="Logo" class="h-8 w-8 rounded-full object-cover group-hover:rotate-12 transition-transform">
        <span class="self-center text-2xl font-semibold text-inherit">Vinyl</span>
      </a>

      <div class="flex items-center md:order-2 gap-4">

        <button id="theme-toggle" class="p-2 rounded-full bg-black/5 dark:bg-white/10 hover:bg-black/10 dark:hover:bg-white/20 transition text-[var(--text-main)]">
            <i id="theme-icon" class="fa-solid fa-moon w-4 text-center"></i>
        </button>

        <button data-collapse-toggle="navbar-user" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm opacity-70 rounded-lg md:hidden hover:bg-black/5 dark:hover:bg-white/10 focus:outline-none text-[var(--text-main)]">
          <i class="fa-solid fa-bars text-xl"></i>
        </button>
      </div>

      <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-user">
        <ul class="flex flex-col font-medium p-4 md:p-0 mt-4 rounded-lg md:flex-row md:space-x-8 md:mt-0 md:border-0 md:bg-transparent">
          <% 
            const shortcutConfig = {
                'global_home': { label: t('nav.home'), url: '/' },
                'global_collection': { label: t('nav.collection'), url: '/collection' },
                'global_wishlist': { label: t('nav.wishlist'), url: '/wishlist' },

                'music': { label: t('media.music'), url: '/collection?type=music', module: 'music' },
                'music_vinyl': { label: t('media.vinyls'), url: '/collection?type=music&format=vinyl', module: 'music' },
                'music_cd': { label: t('media.cds'), url: '/collection?type=music&format=cd', module: 'music' },
                'music_cassette': { label: t('media.cassettes'), url: '/collection?type=music&format=cassette', module: 'music' },

                'books': { label: t('media.books'), url: '/collection?type=books', module: 'books' },
                'book_hardcover': { label: t('media.hardcover'), url: '/collection?type=books&format=hardcover', module: 'books' },
                'book_paperback': { label: t('media.paperback'), url: '/collection?type=books&format=paperback', module: 'books' },
                'book_manga': { label: t('media.manga'), url: '/collection?type=books&format=manga', module: 'books' },
                'book_comic': { label: t('media.comic'), url: '/collection?type=books&format=comic', module: 'books' },
                'book_graphic_novel': { label: t('media.graphic_novel'), url: '/collection?type=books&format=graphic_novel', module: 'books' },

                'dvd': { label: t('media.dvd_gen'), url: '/collection?type=dvd', module: 'dvd' },
                'dvd_dvd': { label: t('media.dvd'), url: '/collection?type=dvd&format=dvd', module: 'dvd' },
                'dvd_bluray': { label: t('media.bluray'), url: '/collection?type=dvd&format=bluray', module: 'dvd' },
                'dvd_4k': { label: t('media.4k'), url: '/collection?type=dvd&format=4k', module: 'dvd' },
                'dvd_vhs': { label: t('media.vhs'), url: '/collection?type=dvd&format=vhs', module: 'dvd' },
                'dvd_laserdisc': { label: t('media.laserdisc'), url: '/collection?type=dvd&format=laserdisc', module: 'dvd' },
                
                'games': { label: t('media.games'), url: '/collection?type=games', module: 'games' }
            };

            if (settings && settings.navbarShortcuts) {
              settings.navbarShortcuts.forEach(id => {
                const item = shortcutConfig[id];
                if (item) {
                  const isModuleActive = item.module ? settings.modules[item.module] : true;
                  
                  if (isModuleActive) { %>
                    <li>
                      <a href="<%= baseUrl + item.url %>" class="block py-2 px-3 md:p-0 text-[var(--text-sub)] hover:text-primary-theme transition-colors">
                        <%= item.label %>
                      </a>
                    </li>
                  <% }
                }
              });
          } %>
        </ul>
      </div>
    </div>
  </nav>

  <script>
    document.body.classList.add('js-ready');

    document.addEventListener('DOMContentLoaded', () => {
        const themeToggleBtn = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const htmlElement = document.documentElement;

        function updateButtonVisuals() {
            const isDark = htmlElement.classList.contains('dark');
            if (themeIcon) {
                themeIcon.className = isDark ? 'fa-solid fa-sun w-4 text-center' : 'fa-solid fa-moon w-4 text-center';
            }
        }

        updateButtonVisuals();

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', async () => {
                htmlElement.classList.toggle('dark');
                updateButtonVisuals();
                const newTheme = htmlElement.classList.contains('dark') ? 'dark' : 'light';
                try {
                    await fetch('<%= baseUrl %>/settings/update-theme', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ theme: newTheme })
                    });
                } catch (e) {}
            });
        }
    });

    window.addEventListener('load', () => {
        const loader = document.getElementById('page-loader');
        if (loader) {
            loader.style.opacity = '0';
            setTimeout(() => { loader.remove(); }, 500);
        }
    });

    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('<%= baseUrl %>/sw.js')
                .then(reg => console.log('[SW] saved', reg.scope))
                .catch(err => console.warn('[SW] error:', err));
        });
    }
  </script>

  <main class="p-6">

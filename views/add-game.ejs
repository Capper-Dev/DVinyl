<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    
    <div class="text-center mb-8 md:mb-12 pt-4 md:pt-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-theme/10 text-primary-theme mb-4">
            <i class="fa-solid fa-gamepad text-3xl"></i>
        </div>
        <h1 class="text-3xl md:text-4xl font-black">Tilføj et Videospil</h1>
        <p class="opacity-60 mt-2">Søg efter titel eller scan stregkoden.</p>
    </div>

    <form action="<%= baseUrl %>/search-games" method="POST" class="max-w-2xl mx-auto mb-10">
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-grow relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none z-10">
                    <i class="fa-solid fa-search opacity-50 group-focus-within:text-primary-theme transition-colors"></i>
                </div>
                <input type="text" name="query" id="searchInput"
                    value="<%= locals.barcode_no_results ? locals.scanned_barcode : '' %>"
                    class="block w-full p-4 pl-12 text-base bg-black/5 dark:bg-white/5 border border-transparent focus:border-primary-theme rounded-2xl focus:ring-2 focus:ring-primary-theme/50 placeholder-opacity-50 transition-all outline-none"
                    placeholder="Spillets titel..." autofocus required>
            </div>
            <button type="submit"
                class="bg-primary-theme hover:brightness-110 text-white font-bold px-8 py-4 rounded-2xl shadow-lg shadow-primary-theme/20 transition-all active:scale-95 flex items-center justify-center gap-2 whitespace-nowrap">
                <i class="fa-solid fa-search"></i>
                Søg
            </button>
        </div>

        <div class="flex items-center gap-3 mt-4 justify-center">
            <span class="text-xs font-bold uppercase opacity-30">ELLER</span>
        </div>

        <div class="flex justify-center mt-3">
            <button type="button" id="btnScan"
                class="bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center gap-2"
                onclick="startBarcodeScanner()">
                <i class="fa-solid fa-barcode"></i>
                Scan en stregkode
            </button>
        </div>

        <div id="scannerContainer" class="hidden mt-6 rounded-2xl overflow-hidden shadow-lg border border-black/10 dark:border-white/10">
            <div class="bg-amber-500/10 text-amber-500 text-[10px] font-bold px-4 py-2 flex items-center gap-2 border-b border-black/5 dark:border-white/5">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>Stregkodescanneren er stadig eksperimentel og virker muligvis ikke på alle enheder.</span>
            </div>
            <div id="reader" class="w-full"></div>
            <p id="scanStatus" class="text-center py-3 text-xs font-bold opacity-60 bg-black/5 dark:bg-white/5">
                Initialiserer...
            </p>
        </div>
    </form>

    <% if (locals.barcode_no_results) { %>
        <div class="max-w-2xl mx-auto mb-8 p-4 rounded-2xl bg-amber-500/10 border border-amber-500/30 flex items-start gap-3">
            <i class="fa-solid fa-triangle-exclamation text-amber-500 mt-0.5"></i>
            <div>
                <% if (locals.barcode_error) { %>
                    <p class="font-semibold text-sm">Stregkode-opslag fejlede</p>
                    <p class="text-xs opacity-60 mt-0.5">Prøv igen, eller søg manuelt på titlen — søgefeltet er klar til brug.</p>
                <% } else { %>
                    <p class="font-semibold text-sm">Stregkoden blev ikke fundet</p>
                    <p class="text-xs opacity-60 mt-0.5">Stregkoden <code class="font-mono"><%= locals.scanned_barcode %></code> matchede ingen spil. Søg på titlen i stedet — søgefeltet er forudfyldt med stregkoden, erstat den blot med spillets titel.</p>
                <% } %>
                <p class="text-xs opacity-50 mt-1">Når du har valgt det rigtige spil fra resultaterne, gemmes stregkoden automatisk til cachen.</p>
            </div>
        </div>
    <% } %>

    <% if (typeof results !== 'undefined' && results !== null) { %>
        <% if (results.length > 0) { %>
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i class="fa-solid fa-list text-primary-theme"></i>
                Søgeresultater
                <span class="text-sm opacity-50 font-normal">(<%= results.length %>)</span>
            </h2>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 md:gap-6">
                <% results.forEach(game => { %>
                    <a href="<%= baseUrl %>/confirm-game/<%= game.igdb_id %><%= typeof scanned_barcode !== 'undefined' && scanned_barcode ? '?barcode=' + scanned_barcode : '' %>"
                       class="group card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all hover:shadow-lg hover:-translate-y-1">
                        
                        <div class="aspect-[3/4] relative overflow-hidden bg-black/5 dark:bg-white/5 flex items-center justify-center">
                            <img src="<%= game.cover_image %>" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-30 scale-110 pointer-events-none">
                            <img src="<%= game.cover_image %>"
                                class="relative z-10 w-full h-full object-contain p-2 transition-transform duration-700 group-hover:scale-105"
                                loading="lazy">

                            <% if (game.year) { %>
                                <span class="absolute top-2 left-2 z-20 text-[10px] font-bold px-2 py-1 rounded backdrop-blur-md bg-black/60 text-white border border-white/10 shadow-sm">
                                    <%= game.year %>
                                </span>
                            <% } %>
                        </div>

                        <div class="p-3">
                            <h3 class="font-bold text-sm truncate leading-tight mb-1"><%= game.title %></h3>
                            <p class="text-[10px] opacity-60 truncate"><%= game.platforms_text || '' %></p>
                            <% if (game.developer) { %>
                                <p class="text-[10px] opacity-40 truncate mt-0.5"><%= game.developer %></p>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-16 border-2 border-dashed border-black/10 dark:border-white/10 rounded-3xl">
                <i class="fa-solid fa-gamepad text-5xl opacity-10 mb-4 block"></i>
                <p class="opacity-50 font-bold">Ingen spil fundet.</p>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    let html5QrCode = null;

    async function startBarcodeScanner() {
        const container = document.getElementById('scannerContainer');
        const btnScan = document.getElementById('btnScan');
        const status = document.getElementById('scanStatus');

        if (html5QrCode && html5QrCode.isScanning) {
            await html5QrCode.stop();
            html5QrCode = null;
            container.classList.add('hidden');
            btnScan.innerHTML = '<i class="fa-solid fa-barcode"></i> Scan en stregkode';
            return;
        }

        container.classList.remove('hidden');
        btnScan.innerHTML = '<i class="fa-solid fa-stop"></i> Stop scan';
        status.textContent = 'Initialiserer...';

        try {
            if (!window.Html5Qrcode) {
                const script = document.createElement('script');
                script.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
                document.head.appendChild(script);
                await new Promise((resolve, reject) => { script.onload = resolve; script.onerror = reject; });
            }

            html5QrCode = new Html5Qrcode("reader");
            await html5QrCode.start(
                { facingMode: "environment" },
                { fps: 10, qrbox: { width: 250, height: 100 } },
                (decodedText) => {
                    status.textContent = 'Fundet! ' + decodedText;
                    document.getElementById('searchInput').value = decodedText;
                    html5QrCode.stop().then(() => {
                        html5QrCode = null;
                        container.classList.add('hidden');
                        btnScan.innerHTML = '<i class="fa-solid fa-barcode"></i> Scan en stregkode';
                        document.querySelector('form').submit();
                    });
                }
            );
        } catch (err) {
            status.textContent = 'Kamerafejl (Tilladelser?)';
            console.error(err);
        }
    }
</script>

<%- include('partials/footer') %>

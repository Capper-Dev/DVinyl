<%- include('partials/header') %>

    <div class="max-w-5xl mx-auto px-4 py-10">

        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-black transition-colors">
                    Personalisering
                </h1>
                <p class="opacity-60 mt-1 transition-colors">
                    Tilpas udseendet af din DVinyl-grænseflade.
                </p>
            </div>
            <a href="<%= baseUrl || '/' %>"
                class="w-fit px-4 py-2 bg-black/5 dark:bg-white/10 rounded-lg text-sm font-bold hover:bg-black/10 dark:hover:bg-white/20 transition-all flex items-center">
                <i class="fa-solid fa-arrow-left mr-2"></i>
                Tilbage til forsiden
            </a>
        </div>

        <form action="<%= baseUrl %>/admin/personnalisation/save" method="POST" class="space-y-8">

            <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors">
                <h2 class="text-xl font-bold mb-6 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                        <i class="fa-solid fa-palette"></i>
                    </div>
                    Temaer & farver
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div class="space-y-2">
                        <label class="block text-xs font-bold uppercase tracking-widest opacity-60">
                            <i class="fa-solid fa-house mr-1"></i>
                            Forside
                        </label>
                        <select name="homePreset"
                            class="w-full bg-black/5 dark:bg-black/20 border border-transparent focus:border-primary-theme rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary-theme/20 outline-none transition-all">
                            <% for (const [key, val] of Object.entries(presets)) { %>
                                <option value="<%= key %>" <%=(settings.theme.home.preset===key) ? 'selected' : '' %>
                                    class="dark:bg-neutral-900">
                                    <%= val.label %>
                                </option>
                                <% } %>
                        </select>
                    </div>

                    <% const themeCats=[ {key: 'music' , label: 'Musik', icon: 'fa-music' },
                        {key: 'books' , label: 'Bøger', icon: 'fa-book' }, {key: 'dvd' , label:
                        'Film / DVD', icon: 'fa-film' }, {key: 'games' , label:
                        'Videospil', icon: 'fa-gamepad' } ] %>

                        <% themeCats.forEach((tTheme)=> { %>
                            <div class="space-y-2">
                                <label class="block text-xs font-bold uppercase tracking-widest opacity-60">
                                    <i class="fa-solid <%= tTheme.icon %> mr-1"></i>
                                    <%= tTheme.label %>
                                </label>
                                <select name="<%= tTheme.key %>Preset"
                                    class="w-full bg-black/5 dark:bg-black/20 border border-transparent focus:border-primary-theme rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary-theme/20 outline-none transition-all">
                                    <% for (const [key, val] of Object.entries(presets)) { %>
                                        <option value="<%= key %>" <%=(settings.theme[tTheme.key] &&
                                            settings.theme[tTheme.key].preset===key) ? 'selected' : '' %>
                                            class="dark:bg-neutral-900">
                                            <%= val.label %>
                                        </option>
                                        <% } %>
                                </select>
                            </div>
                            <% }) %>

                </div>
            </div>

            <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors mt-8">
                <h2 class="text-xl font-bold mb-2 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    Navigationskonfiguration
                </h2>
                <p class="text-sm opacity-60 mb-6">
                    Vælg op til 6 genveje til navigationsbjælken.
                </p>

                <div class="space-y-6">
                    <% const shortcutGroups=[ { label: 'Generelt', active: true, options: [ {
                        id: 'global_home' , label: 'Forside' }, { id: 'global_collection' , label:
                        'Samling' }, { id: 'global_wishlist' , label: 'Ønskeliste' } ] }, { label:
                        'Musik', active: settings.modules.music, options: [ { id: 'music' , label:
                        'Musik' }, { id: 'music_vinyl' , label: 'Vinyler' }, { id: 'music_cd' , label:
                        "CD'er" }, { id: 'music_cassette' , label: 'Kassetter' } ] }, { label:
                        'Bøger', active: settings.modules.books, options: [ { id: 'books' , label:
                        'Bøger' }, { id: 'book_hardcover' , label: 'Hardcover' }, {
                        id: 'book_paperback' , label: 'Paperback' }, { id: 'book_manga' , label:
                        'Manga' }, { id: 'book_comic' , label: 'Tegneserie' }, { id: 'book_graphic_novel' ,
                        label: 'Grafisk roman' } ] }, { label: "DVD'er", active:
                        settings.modules.dvd, options: [ { id: 'dvd' , label: 'Film / TV-serier' }, { id: 'dvd_dvd' ,
                        label: 'DVD' }, { id: 'dvd_bluray' , label: 'Blu-ray' }, { id: 'dvd_4k' ,
                        label: '4K Ultra HD' }, { id: 'dvd_vhs' , label: 'VHS' }, { id: 'dvd_laserdisc' ,
                        label: 'Laserdisc' } ] }, { label: 'Videospil', active:
                        settings.modules.games, options: [ { id: 'games' , label: 'Videospil' }, { id: 'game_physical' ,
                        label: 'Fysisk' }, { id: 'game_collector' , label: 'Collector' }, { id: 'game_limited' ,
                        label: 'Limited' }, { id: 'game_steelbook' , label: 'Steelbook' } ] } ] %>

                        <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide flex-nowrap">
                            <% shortcutGroups.forEach((group, idx)=> { %>
                                <% if (group.active) { %>
                                    <button type="button" onclick="switchTab('shortcuts', <%= idx %>)"
                                        id="tab-shortcuts-<%= idx %>"
                                        class="tab-btn-shortcuts shrink-0 px-5 py-2.5 rounded-xl font-bold text-sm whitespace-nowrap transition-all border-2 border-transparent text-black/50 dark:text-white/50 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10">
                                        <%= group.label %>
                                    </button>
                                    <% } %>
                                        <% }) %>
                        </div>

                        <div class="mt-4">
                            <% shortcutGroups.forEach((group, idx)=> { %>
                                <% if (group.active) { %>
                                    <div id="content-shortcuts-<%= idx %>"
                                        class="tab-content-shortcuts hidden bg-black/5 dark:bg-white/5 rounded-2xl p-4 md:p-5">
                                        <div class="flex flex-wrap gap-2 md:gap-3">
                                            <% group.options.forEach(opt=> { %>
                                                <label class="shortcut-option cursor-pointer group relative">
                                                    <input type="checkbox" name="navbarShortcuts" value="<%= opt.id %>"
                                                        <%=(settings.navbarShortcuts &&
                                                        settings.navbarShortcuts.includes(opt.id)) ? 'checked' : '' %>
                                                    class="sr-only">
                                                    <div
                                                        class="flex items-center gap-2 px-4 py-2.5 rounded-xl border-2 border-transparent bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 opacity-80 transition-all duration-300 font-bold group-hover:bg-black/10 dark:group-hover:bg-white/10 group-has-[:checked]:bg-primary-theme group-has-[:checked]:border-primary-theme group-has-[:checked]:text-white group-has-[:checked]:opacity-100 group-has-[:checked]:shadow-lg group-has-[:checked]:-translate-y-0.5">
                                                        <i
                                                            class="fa-solid fa-plus text-[10px] opacity-40 block group-has-[:checked]:hidden transition-transform"></i>
                                                        <i
                                                            class="fa-solid fa-check text-[10px] hidden group-has-[:checked]:block transition-transform"></i>
                                                        <span class="text-sm">
                                                            <%= opt.label %>
                                                        </span>
                                                    </div>
                                                </label>
                                                <% }) %>
                                        </div>
                                    </div>
                                    <% } %>
                                        <% }) %>
                        </div>
                </div>
            </div>


            <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors mt-8">
                <h2 class="text-xl font-bold mb-2 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    Hurtig tilføjelse
                </h2>
                <p class="text-sm opacity-60 mb-6">
                    Hvis aktiveret, fører "Tilføj et element"-knappen direkte til den valgte formular og springer valgmenuen over.
                </p>

                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    <% const fastAddOptions=[ { value: '' , label: 'Deaktiveret (modal)', icon: 'fa-xmark' ,
                        color: 'peer-checked:bg-gray-500' }, ]; if (settings.modules.music) { fastAddOptions.push( {
                        value: 'vinyl' , label: 'Vinyler', icon: 'fa-record-vinyl' ,
                        color: 'peer-checked:bg-green-600' }, { value: 'cd' , label: "CD'er",
                        icon: 'fa-compact-disc' , color: 'peer-checked:bg-blue-600' }, { value: 'cassette' , label:
                        'Kassetter', icon: 'fa-tape' , color: 'peer-checked:bg-orange-600' } ); } if
                        (settings.modules.books) { fastAddOptions.push( { value: 'book' , label: 'Bøger',
                        icon: 'fa-book' , color: 'peer-checked:bg-amber-600' } ); } if (settings.modules.dvd) {
                        fastAddOptions.push( { value: 'dvd' , label: 'Film / TV-serier', icon: 'fa-film' ,
                        color: 'peer-checked:bg-red-600' } ); } if (settings.modules.games) {
                        fastAddOptions.push( { value: 'game' , label: 'Videospil', icon: 'fa-gamepad' ,
                        color: 'peer-checked:bg-emerald-600' } ); } %>
                        <% fastAddOptions.forEach(opt=> { %>
                            <label class="cursor-pointer relative group">
                                <input type="radio" name="fastAdd" value="<%= opt.value %>" class="peer sr-only"
                                    <%=(settings.fastAdd===opt.value || (!settings.fastAdd && opt.value==='' ))
                                    ? 'checked' : '' %>>
                                <div
                                    class="flex items-center gap-3 p-3 rounded-xl border border-black/5 dark:border-white/5 bg-black/5 dark:bg-white/5 transition-all peer-checked:text-white opacity-60 peer-checked:opacity-100 peer-checked:shadow-md <%= opt.color %>">
                                    <i class="fa-solid <%= opt.icon %> text-base w-4 text-center"></i>
                                    <span class="text-sm font-medium">
                                        <%= opt.label %>
                                    </span>
                                </div>
                            </label>
                            <% }) %>
                </div>
            </div>


            <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors mt-8">
                <h2 class="text-xl font-bold mb-2 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                        <i class="fa-solid fa-chart-simple"></i>
                    </div>
                    Statistik-widgets
                </h2>
                <p class="text-sm opacity-60 mb-6">
                    Vælg de statistikker, du vil se på dit dashboard
                </p>

                <div class="space-y-6">
                    <% const statOptions=[
                        {
                            group: 'Generelt',
                            active: true,
                            options: [
                                { id: 'total' , label: 'Samlet samling' }
                            ]
                        },
                        {
                            group: 'Musik',
                            active: settings.modules.music,
                            options: [
                                { id: 'vinyl' , label: 'Vinyler' },
                                { id: 'cd' , label: "CD'er" },
                                { id: 'cassette' , label: 'Kassetter' },
                                { id: 'artist' , label: 'Yndlingskunstner' },
                                { id: 'music_genre', label: 'Top genre' },
                                { id: 'label', label: 'Top pladeselskab' }
                            ]
                        },
                        {
                            group: 'Bøger',
                            active: settings.modules.books,
                            options: [
                                { id: 'book_total' , label: 'Bøger i alt' },
                                { id: 'book_hardcover' , label: 'Hardcovers' },
                                { id: 'book_paperback' , label: 'Paperbacks' },
                                { id: 'book_manga' , label: 'Mangas' },
                                { id: 'book_comic' , label: 'Tegneserier' },
                                { id: 'author' , label: 'Yndlingsforfatter' },
                                { id: 'publisher', label: 'Top forlag' }
                            ]
                        },
                        {
                            group: "DVD'er",
                            active: settings.modules.dvd,
                            options: [
                                { id: 'dvd_total' , label: 'Videoer i alt' },
                                { id: 'dvd_bluray' , label: 'Blu-rays' },
                                { id: 'dvd_4k' , label: '4K Ultra HD' },
                                { id: 'dvd_vhs' , label: 'VHS' },
                                { id: 'dvd_laserdisc' , label: 'Laserdiscs' },
                                { id: 'director' , label: 'Yndlingsinstruktør' },
                                { id: 'studio', label: 'Top studie' }
                            ]
                        },
                        {
                            group: 'Videospil',
                            active: settings.modules.games,
                            options: [
                                { id: 'game_total' , label: 'Videospil i alt' },
                                { id: 'game_physical' , label: 'Fysisk' },
                                { id: 'game_collector' , label: 'Collector' },
                                { id: 'game_limited' , label: 'Limited' },
                                { id: 'game_steelbook' , label: 'Steelbook' },
                                { id: 'game_developer' , label: 'Top udvikler' },
                                { id: 'game_publisher', label: 'Top udgiver (spil)' }
                            ]
                        }
                    ] %>

                        <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide flex-nowrap">
                            <% statOptions.forEach((group, idx)=> { %>
                                <% if (group.active) { %>
                                    <button type="button" onclick="switchTab('stats', <%= idx %>)"
                                        id="tab-stats-<%= idx %>"
                                        class="tab-btn-stats shrink-0 px-5 py-2.5 rounded-xl font-bold text-sm whitespace-nowrap transition-all border-2 border-transparent text-black/50 dark:text-white/50 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10">
                                        <%= group.group %>
                                    </button>
                                    <% } %>
                                        <% }) %>
                        </div>

                        <div class="mt-4">
                            <% statOptions.forEach((group, idx)=> { %>
                                <% if (group.active) { %>
                                    <div id="content-stats-<%= idx %>"
                                        class="tab-content-stats hidden bg-black/5 dark:bg-white/5 rounded-2xl p-4 md:p-5">
                                        <div class="flex flex-wrap gap-2 md:gap-3">
                                            <% group.options.forEach(opt=> { %>
                                                <label class="cursor-pointer group relative">
                                                    <input type="checkbox" name="statsWidgets" value="<%= opt.id %>"
                                                        <%=(settings.statsWidgets &&
                                                        settings.statsWidgets.includes(opt.id)) ? 'checked' : '' %>
                                                    class="sr-only">
                                                    <div
                                                        class="flex items-center gap-2 px-4 py-2.5 rounded-xl border-2 border-transparent bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 opacity-80 transition-all duration-300 font-bold group-hover:bg-black/10 dark:group-hover:bg-white/10 group-has-[:checked]:bg-primary-theme group-has-[:checked]:border-primary-theme group-has-[:checked]:text-white group-has-[:checked]:opacity-100 group-has-[:checked]:shadow-lg group-has-[:checked]:-translate-y-0.5">
                                                        <i
                                                            class="fa-solid fa-plus text-[10px] opacity-40 block group-has-[:checked]:hidden transition-transform"></i>
                                                        <i
                                                            class="fa-solid fa-check text-[10px] hidden group-has-[:checked]:block transition-transform"></i>
                                                        <span class="text-sm">
                                                            <%= opt.label %>
                                                        </span>
                                                    </div>
                                                </label>
                                                <% }) %>
                                        </div>
                                    </div>
                                    <% } %>
                                        <% }) %>
                        </div>
                </div>
            </div>


            <div class="flex justify-end pt-4">
                <button type="submit"
                    class="w-full md:w-auto px-10 py-4 bg-primary-theme text-white font-black rounded-2xl hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary-theme/20 flex items-center justify-center gap-3">
                    <i class="fa-solid fa-save"></i>
                    Gem præferencer
                </button>
            </div>
        </form>
    </div>

    <script>
        function switchTab(groupName, index) {
            const allContents = document.querySelectorAll('.tab-content-' + groupName);
            allContents.forEach(el => el.classList.add('hidden'));

            const allBtns = document.querySelectorAll('.tab-btn-' + groupName);
            allBtns.forEach(btn => {
                btn.classList.remove('bg-primary-theme', 'text-white', 'border-primary-theme', 'opacity-100', 'shadow-md');
                btn.classList.add('bg-black/5', 'dark:bg-white/5', 'text-black/50', 'dark:text-white/50');
            });

            const targetContent = document.getElementById('content-' + groupName + '-' + index);
            if (targetContent) targetContent.classList.remove('hidden');

            const targetBtn = document.getElementById('tab-' + groupName + '-' + index);
            if (targetBtn) {
                targetBtn.classList.remove('bg-black/5', 'dark:bg-white/5', 'text-black/50', 'dark:text-white/50');
                targetBtn.classList.add('bg-primary-theme', 'text-white', 'border-primary-theme', 'opacity-100', 'shadow-md');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const firstShortcutTab = document.querySelector('.tab-btn-shortcuts');
            if (firstShortcutTab) {
                const idx = firstShortcutTab.id.split('-').pop();
                switchTab('shortcuts', idx);
            }

            const firstStatsTab = document.querySelector('.tab-btn-stats');
            if (firstStatsTab) {
                const idx = firstStatsTab.id.split('-').pop();
                switchTab('stats', idx);
            }
        });

        const checkboxes = document.querySelectorAll('input[name="navbarShortcuts"]');
        const maxAllowed = 6;

        checkboxes.forEach(cb => {
            cb.addEventListener('change', () => {
                const checkedCount = document.querySelectorAll('input[name="navbarShortcuts"]:checked').length;
                if (checkedCount > maxAllowed) {
                    cb.checked = false;
                    alert("Du kan ikke vælge mere end 6 genveje.");
                }
            });
        });
    </script>

    <%- include('partials/footer') %>

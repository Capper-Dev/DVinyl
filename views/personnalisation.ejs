<%- include('partials/header') %>

<div class="max-w-5xl mx-auto px-4 py-10">
    
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-black transition-colors">
                <%= t('perso.title') %>
            </h1>
            <p class="opacity-60 mt-1 transition-colors">
                <%= t('perso.subtitle', { siteName: settings.siteName }) %>
            </p>
        </div>
        <a href="/admin" class="w-fit px-4 py-2 bg-black/5 dark:bg-white/10 rounded-lg text-sm font-bold hover:bg-black/10 dark:hover:bg-white/20 transition-all flex items-center">
            <i class="fa-solid fa-arrow-left mr-2"></i>
            <%= t('perso.backAdmin') %>
        </a>
    </div>

    <form action="/admin/personnalisation/save" method="POST" class="space-y-8">
        
        <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                    <i class="fa-solid fa-cubes"></i>
                </div>
                <%= t('perso.modules.title') %>
            </h2>
       
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% const mods = [
                    {key: 'music', label: t('perso.modules.music'), icon: 'fa-music', color: 'pink'},
                    {key: 'books', label: t('perso.modules.books'), icon: 'fa-book', color: 'purple'},
                    {key: 'dvd', label: t('perso.modules.dvd'), icon: 'fa-film', color: 'orange'}
                ] %>
                
                <% mods.forEach((mod) => { %>
                    <label class="relative flex items-center justify-between p-4 rounded-2xl border-2 cursor-pointer transition-all duration-200 
                        <%= settings.modules[mod.key] ? 'border-primary-theme bg-primary-theme/5' : 'border-transparent bg-black/5 dark:bg-white/5 opacity-60 hover:opacity-100' %>">
                        
                        <div class="flex items-center gap-3">
                            <i class="fa-solid <%= mod.icon %> <%= settings.modules[mod.key] ? 'text-primary-theme' : '' %>"></i>
                            <span class="font-bold"><%= mod.label %></span>
                        </div>
                        
                        <input type="checkbox" name="<%= mod.key %>Active" 
                               <%= settings.modules[mod.key] ? 'checked' : '' %> 
                               class="w-5 h-5 rounded text-primary-theme focus:ring-primary-theme border-black/10 dark:border-white/20 bg-transparent">
                    </label>
                <% }) %>
            </div>
        </div>

        <div class="card-theme rounded-3xl p-6 shadow-xl transition-colors">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-theme/10 text-primary-theme flex items-center justify-center">
                    <i class="fa-solid fa-palette"></i>
                </div>
                <%= t('perso.themes.title') %>
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-widest opacity-60">
                        <i class="fa-solid fa-house mr-1"></i> <%= t('perso.themes.home') %>
                    </label>
                    <select name="homePreset" class="w-full bg-black/5 dark:bg-black/20 border border-transparent focus:border-primary-theme rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary-theme/20 outline-none transition-all">
                        <% for (const [key, val] of Object.entries(presets)) { %>
                            <option value="<%= key %>" <%= (settings.theme.home.preset === key) ? 'selected' : '' %> class="dark:bg-neutral-900">
                                <%= val.label %>
                            </option>
                        <% } %>
                    </select>
                </div>

                <% const themeCats = [
                    {key: 'music', label: t('perso.themes.music'), icon: 'fa-music'},
                    {key: 'books', label: t('perso.themes.books'), icon: 'fa-book'},
                    {key: 'dvd', label: t('perso.themes.dvd'), icon: 'fa-film'}
                ] %>

                <% themeCats.forEach((tTheme) => { %>
                    <div class="space-y-2">
                        <label class="block text-xs font-bold uppercase tracking-widest opacity-60">
                            <i class="fa-solid <%= tTheme.icon %> mr-1"></i> <%= tTheme.label %>
                        </label>
                        <select name="<%= tTheme.key %>Preset" class="w-full bg-black/5 dark:bg-black/20 border border-transparent focus:border-primary-theme rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary-theme/20 outline-none transition-all">
                            <% for (const [key, val] of Object.entries(presets)) { %>
                                <option value="<%= key %>" <%= (settings.theme[tTheme.key] && settings.theme[tTheme.key].preset === key) ? 'selected' : '' %> class="dark:bg-neutral-900">
                                    <%= val.label %>
                                </option>
                            <% } %>
                        </select>
                    </div>
                <% }) %>

            </div>
        </div>

        <div class="flex justify-end pt-4">
            <button type="submit" class="w-full md:w-auto px-10 py-4 bg-primary-theme text-white font-black rounded-2xl hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary-theme/20 flex items-center justify-center gap-3">
                <i class="fa-solid fa-save"></i>
                <%= t('perso.save') %>
            </button>
        </div>
    </form>
</div>

<%- include('partials/footer') %>